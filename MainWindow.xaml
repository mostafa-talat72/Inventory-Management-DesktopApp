<Window x:Class="ProductApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MTE Stock"
        Icon="pack://application:,,,/app.ico"
        Width="1300" Height="800"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="{DynamicResource AppBackground}">
    <Window.Resources>
        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,3,0" />
            <Setter Property="Foreground" Value="{DynamicResource NavTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Right"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                <Setter TargetName="border" Property="Background" Value="#0DFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="LogoutButton">
            <Setter Property="Height" Value="46" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,3,0" />
            <Setter Property="Foreground" Value="#90A4AE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Right"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#18EF5350" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#EF5350" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30EF5350" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#EF5350" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.3" Color="#000" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,32,0,24">
                    <Border Width="64" Height="64" CornerRadius="16"
                            HorizontalAlignment="Center" Margin="0,0,0,12"
                            BorderThickness="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.2" Color="#000" />
                        </Border.Effect>
                        <Image Source="pack://application:,,,/app.ico"
                               Width="64" Height="64" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <TextBlock Text="MTE Stock" FontSize="22" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="TxtLocationDisplay2" Text="" FontSize="13" Foreground="{DynamicResource NavTextBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Divider -->
                <Border Grid.Row="1" Height="1" Background="#FFFFFF" Opacity="0.1" Margin="24,0" />

                <!-- Navigation -->
                <StackPanel Grid.Row="2" Margin="12,8,12,0">
                    <Button x:Name="BtnDashboard" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Dashboard">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="لوحة التحكم" FontSize="14" VerticalAlignment="Center" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="20" Height="20" Fill="White" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Data="M3,13H8V23H3V13M10,14H15V23H10V14M17,10H22V23H17V10M3,3.03L8,3V11H3V3.03M10,4H15V12H10V4M17,5H22V8H17V5Z" />
                        </Grid>
                    </Button>
                    <Button x:Name="BtnProducts" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Products">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="المنتجات" FontSize="14" VerticalAlignment="Center" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="20" Height="20" Fill="White" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                        </Grid>
                    </Button>
                    <Button x:Name="BtnCustomers" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Customers">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="العملاء" FontSize="14" VerticalAlignment="Center" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="20" Height="20" Fill="White" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                        </Grid>
                    </Button>
                    <Button x:Name="BtnInvoices" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Invoices">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="الفواتير" FontSize="14" VerticalAlignment="Center" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="20" Height="20" Fill="White" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Data="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 18H6V4h2v5l2.5-1.5L13 9V4h5v16z" />
                        </Grid>
                    </Button>
                    <Button x:Name="BtnReports" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Reports">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="التقارير" FontSize="14" VerticalAlignment="Center" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="20" Height="20" Fill="White" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Data="M9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4zm2 2H5V5h14v14zm0-16H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" />
                        </Grid>
                    </Button>
                    <Button x:Name="BtnSettings" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Settings">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="الإعدادات" FontSize="14" VerticalAlignment="Center" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="20" Height="20" Fill="White" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="3" Margin="12,4,12,0">
                    <Border Height="1" Background="#FFFFFF" Opacity="0.06" Margin="4,0,4,6" />
                    <Button Style="{StaticResource LogoutButton}" Click="Logout_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="تسجيل الخروج" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="18" Height="18" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,12,0"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                  Data="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                        </Grid>
                    </Button>

                    <!-- Dark / Light Mode Toggle -->
                    <Border Height="1" Background="#FFFFFF" Opacity="0.06" Margin="4,6,4,6" />
                    <Button x:Name="BtnThemeToggle" Click="BtnThemeToggle_Click"
                            Style="{StaticResource NavButton}"
                            Foreground="{DynamicResource ThemeToggleFg}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Moon icon (shown in light mode, click → go dark) -->
                            <Path x:Name="IconMoon"
                                  FlowDirection="LeftToRight" Grid.Column="0"
                                  Width="18" Height="18" Fill="{DynamicResource ThemeToggleFg}"
                                  Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Data="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-2.98 0-5.4-2.42-5.4-5.4 0-1.81.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z" />
                            <!-- Sun icon (shown in dark mode, click → go light) -->
                            <Path x:Name="IconSun"
                                  FlowDirection="LeftToRight" Grid.Column="0"
                                  Width="18" Height="18" Fill="{DynamicResource ThemeToggleFg}"
                                  Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Visibility="Collapsed"
                                  Data="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z" />
                            <TextBlock x:Name="TxtThemeLabel"
                                       Grid.Column="1" Text="الوضع الليلي"
                                       FontSize="13" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeToggleFg}" />
                        </Grid>
                    </Button>

                    <!-- Hide / Show Amounts Toggle -->
                    <Button x:Name="BtnAmountsToggle" Click="BtnAmountsToggle_Click"
                            Style="{StaticResource NavButton}"
                            Foreground="#90CAF9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Eye-off icon (amounts hidden → click to show) -->
                            <Path x:Name="IconEyeOff"
                                  FlowDirection="LeftToRight" Grid.Column="0"
                                  Width="18" Height="18" Fill="#90CAF9"
                                  Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.79 8,5.3L10.17,7.47C10.74,7.18 11.35,7 12,7Z" />
                            <!-- Eye icon (amounts visible → click to hide) -->
                            <Path x:Name="IconEye"
                                  FlowDirection="LeftToRight" Grid.Column="0"
                                  Width="18" Height="18" Fill="#90CAF9"
                                  Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                  Visibility="Collapsed"
                                  Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" />
                            <TextBlock x:Name="TxtAmountsLabel"
                                       Grid.Column="1" Text="إظهار الأرقام"
                                       FontSize="13" VerticalAlignment="Center"
                                       Foreground="#90CAF9" />
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Divider -->
                <Border Grid.Row="4" Height="1" Background="#FFFFFF" Opacity="0.1" Margin="24,0" />

                <!-- Footer -->
                <StackPanel Grid.Row="5" Margin="24,16,24,20">
                    <TextBlock Text="الإصدار 1.0" FontSize="11" Foreground="{DynamicResource BodyTextBrush}"
                               HorizontalAlignment="Right" />
                    <!-- Developer Signature -->
                    <Border Margin="0,10,0,0" Padding="0,10,0,0"
                            BorderThickness="0,1,0,0" BorderBrush="#33FFFFFF">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="تم تصميم وتطوير هذا النظام بواسطة"
                                       FontSize="11" Foreground="{DynamicResource BodyTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0" />
                            <TextBlock Text="م. مصطفى طلعت - للحلول البرمجية"
                                       FontSize="12" FontWeight="Bold" Foreground="{DynamicResource NavTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0" />
                            <TextBlock Text="01116626164"
                                       FontSize="13" Foreground="{DynamicResource SubtleTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,1,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Column="1" Background="{DynamicResource AppBackground}">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
        </Border>

        <!-- Overlay -->
        <Border x:Name="OverlayBackground" Grid.ColumnSpan="2" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100" MouseDown="OverlayBackground_MouseDown" />
        <Border x:Name="OverlayContainer" Grid.ColumnSpan="2"
                Visibility="Collapsed" Panel.ZIndex="101"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Margin="40,0">
            <Grid HorizontalAlignment="Center" MaxWidth="1800">
                <Border Background="{DynamicResource OverlayCardBackground}" CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" Color="#000000" />
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MaxHeight="680">
                        <ContentControl x:Name="OverlayContent" HorizontalContentAlignment="Center" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Toast Notifications -->
        <StackPanel x:Name="ToastContainer" Grid.ColumnSpan="2"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,20,24" Panel.ZIndex="200" />
    </Grid>
</Window>
