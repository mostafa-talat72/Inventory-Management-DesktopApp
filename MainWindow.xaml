<Window x:Class="ProductApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نظام إدارة المخزون والمبيعات"
        Width="1300" Height="800"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#F0F2F5">
    <Window.Resources>
        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Height" Value="48" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#B0BEC5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="0,0,3,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0DFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1A237E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="24,0">
                    <Path Width="36" Height="36" Fill="White" Stretch="Uniform" Margin="0,0,0,4"
                          Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                    <TextBlock Text="نظام المخزون" FontSize="17" FontWeight="Bold" Foreground="White" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnProducts" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Products" IsEnabled="False">
                        <Grid Margin="0,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="20" Height="20" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                            <TextBlock Grid.Column="1" Text="  المنتجات" FontSize="15" VerticalAlignment="Center" Margin="12,0,0,0" />
                        </Grid>
                    </Button>
                    <Button x:Name="BtnCustomers" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Customers">
                        <Grid Margin="0,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="20" Height="20" Fill="#90CAF9" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                            <TextBlock Grid.Column="1" Text="  العملاء" FontSize="15" VerticalAlignment="Center" Margin="12,0,0,0" />
                        </Grid>
                    </Button>
                    <Button x:Name="BtnInvoices" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Invoices">
                        <Grid Margin="0,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="20" Height="20" Fill="#90CAF9" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 18H6V4h2v5l2.5-1.5L13 9V4h5v16z" />
                            <TextBlock Grid.Column="1" Text="  الفواتير" FontSize="15" VerticalAlignment="Center" Margin="12,0,0,0" />
                        </Grid>
                    </Button>
                    <Button x:Name="BtnReports" Style="{StaticResource NavButton}" Click="NavigateToPage" Tag="Reports">
                        <Grid Margin="0,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="20" Height="20" Fill="#90CAF9" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4zm2 2H5V5h14v14zm0-16H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" />
                            <TextBlock Grid.Column="1" Text="  التقارير" FontSize="15" VerticalAlignment="Center" Margin="12,0,0,0" />
                        </Grid>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="3" Text="الإصدار 1.0" FontSize="11" Foreground="#607D8B" Margin="20,0,0,12" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Column="1" Background="#F0F2F5">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
        </Border>

        <!-- Overlay -->
        <Border x:Name="OverlayBackground" Grid.ColumnSpan="2" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100" MouseDown="OverlayBackground_MouseDown" />
        <Border x:Name="OverlayContainer" Grid.ColumnSpan="2"
                Visibility="Collapsed" Panel.ZIndex="101"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Margin="40,0">
            <Grid HorizontalAlignment="Center" MaxWidth="1800">
                <Border Background="White" CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" Color="#000000" />
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MaxHeight="680">
                        <ContentControl x:Name="OverlayContent" HorizontalContentAlignment="Center" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Toast Notifications -->
        <StackPanel x:Name="ToastContainer" Grid.ColumnSpan="2"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,20,24" Panel.ZIndex="200" />
    </Grid>
</Window>
