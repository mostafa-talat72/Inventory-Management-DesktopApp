<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:ProductApp.Converters">

    <!-- ═══════════════════════════════════════════
         BRAND COLORS (unchanged in both themes)
    ═══════════════════════════════════════════ -->
    <SolidColorBrush x:Key="PrimaryBrush"       Color="#1A237E" />
    <SolidColorBrush x:Key="PrimaryLightBrush"  Color="#534BAE" />
    <SolidColorBrush x:Key="PrimaryDarkBrush"   Color="#000051" />
    <SolidColorBrush x:Key="AccentBrush"        Color="#00897B" />
    <SolidColorBrush x:Key="SuccessBrush"       Color="#2E7D32" />
    <SolidColorBrush x:Key="WarningBrush"       Color="#F57F17" />
    <SolidColorBrush x:Key="DangerBrush"        Color="#C62828" />

    <!-- ═══════════════════════════════════════════
         LIGHT THEME SEMANTIC COLORS
    ═══════════════════════════════════════════ -->

    <!-- App / page backgrounds -->
    <SolidColorBrush x:Key="AppBackground"          Color="#F0F2F5" />
    <SolidColorBrush x:Key="CardBackground"         Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBackgroundAlt"      Color="#FAFAFA" />
    <SolidColorBrush x:Key="SurfaceBackground"      Color="#F8F9FA" />
    <SolidColorBrush x:Key="InputBackground"        Color="#FAFAFA" />
    <SolidColorBrush x:Key="InputBackgroundAlt"     Color="#F8F9FA" />

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"       Color="#1A237E" />
    <SolidColorBrush x:Key="HeadingTextBrush"       Color="#37474F" />
    <SolidColorBrush x:Key="BodyTextBrush"          Color="#546E7A" />
    <SolidColorBrush x:Key="SubtleTextBrush"        Color="#78909C" />
    <SolidColorBrush x:Key="MutedTextBrush"         Color="#90A4AE" />
    <SolidColorBrush x:Key="NavTextBrush"           Color="#90CAF9" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush"            Color="#E0E0E0" />
    <SolidColorBrush x:Key="BorderBrushLight"       Color="#E8E8E8" />
    <SolidColorBrush x:Key="DividerBrush"           Color="#EEEEEE" />

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBackground"      Color="#1A237E" />
    <SolidColorBrush x:Key="SidebarDivider"         Color="#FFFFFF" />
    <Color            x:Key="SidebarDividerOpacity">#1AFFFFFF</Color>

    <!-- Overlay / Modal -->
    <SolidColorBrush x:Key="OverlayCardBackground"  Color="#FFFFFF" />
    <SolidColorBrush x:Key="OverlayFooterBrush"     Color="#FAFAFA" />
    <SolidColorBrush x:Key="OverlayFooterBorder"    Color="#E8E8E8" />
    <SolidColorBrush x:Key="DialogHeaderBrush"      Color="#FFFFFF" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="SecondaryButtonBg"      Color="#F5F5F5" />
    <SolidColorBrush x:Key="SecondaryButtonFg"      Color="#546E7A" />
    <SolidColorBrush x:Key="SecondaryButtonBorder"  Color="#E0E0E0" />

    <!-- Theme toggle icon colors -->
    <SolidColorBrush x:Key="ThemeToggleFg"          Color="#90CAF9" />

    <!-- ═══════════════════════════════════════════
         SCROLLBAR &amp; SCROLLVIEWER
    ═══════════════════════════════════════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8" />
        <Setter Property="MinWidth" Value="8" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="local:ScrollBehavior.ForceMouseWheel" Value="True" />
    </Style>

    <!-- ═══════════════════════════════════════════
         GLOBAL CONTROL STYLES
    ═══════════════════════════════════════════ -->

    <!-- Global TextBox style — ensures text is always visible in both themes -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource HeadingTextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource HeadingTextBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Background" Value="#1A237E" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.9" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="#00897B" />
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackground}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12" Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource HeadingTextBrush}" />
        <Setter Property="Margin" Value="0,12,0,8" />
    </Style>

    <Style x:Key="FormField" TargetType="Control">
        <Setter Property="Padding" Value="8" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="Background" Value="{DynamicResource InputBackground}" />
    </Style>
    <Style x:Key="FormFieldPassword" TargetType="PasswordBox" BasedOn="{StaticResource FormField}" />

</ResourceDictionary>
