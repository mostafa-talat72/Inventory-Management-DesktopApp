<UserControl x:Class="ProductApp.Views.OrderDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wm="clr-namespace:ProductApp.Converters"
             FlowDirection="RightToLeft"
             MinWidth="500" MaxWidth="800">
    <StackPanel Margin="20">
        <TextBlock x:Name="TxtInvoiceInfo" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />

        <!-- Product search -->
        <TextBox x:Name="TxtSearch" wm:WatermarkBehavior.Watermark="بحث عن منتج..." TextChanged="TxtSearch_TextChanged" Margin="0,0,0,8" />

        <!-- Product cards -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200" Margin="0,0,0,8">
            <ItemsControl x:Name="ProductCards">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="190" Height="110" Margin="5" CornerRadius="8"
                                Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Color="#000" />
                            </Border.Effect>
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock Grid.Row="1" Text="{Binding UnitsDisplay}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,2,0,0" />
                                <TextBlock Grid.Row="2" Text="{Binding StockDisplay}" FontSize="11" Foreground="{DynamicResource BodyTextBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="3" Text="{Binding PriceDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#00897B" />
                            </Grid>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}" />
                            </Border.InputBindings>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="TxtSelectedProduct" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4" Visibility="Collapsed" />

        <!-- Prices -->
        <Border x:Name="PricesPanel" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16"
                Background="{DynamicResource CardBackgroundAlt}" Visibility="Collapsed" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="أسعار المنتج" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ItemsControl x:Name="PriceList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,0,0,1" Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Vertical">
                                        <TextBlock Text="قطاعي" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" />
                                        <TextBlock Text="{Binding RetailDisplay}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Vertical">
                                        <TextBlock Text="جملة" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" />
                                        <TextBlock Text="{Binding WholesaleDisplay}" FontSize="14" FontWeight="Bold" Foreground="#00897B" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Quantity -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16"
                Background="{DynamicResource CardBackgroundAlt}" Visibility="Collapsed" x:Name="QtyPanel" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="الكمية" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBlock Text="كرتونة" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="TxtCartonQty" Text="0" TextChanged="Qty_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4">
                        <TextBlock Text="علبة" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="TxtBoxQty" Text="0" TextChanged="Qty_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4">
                        <TextBlock Text="قطعة" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="TxtPieceQty" Text="0" TextChanged="Qty_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="4">
                        <TextBlock Text="نوع السعر" FontSize="12" Margin="0,0,0,4" />
                        <ComboBox x:Name="CmbPriceType" SelectedIndex="0">
                            <ComboBoxItem Tag="Retail" Content="قطاعي" />
                            <ComboBoxItem Tag="Wholesale" Content="جملة" />
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Total -->
        <Border x:Name="TotalPanel" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16"
                Background="#E8F5E9" Visibility="Collapsed" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="الإجمالي" FontSize="18" VerticalAlignment="Center" />
                <TextBlock x:Name="TxtTotal" Grid.Column="1" Text="0.00 ج.م" FontSize="22" FontWeight="Bold" Foreground="#2E7D32" />
            </Grid>
        </Border>

        <TextBox x:Name="TxtNotes" wm:WatermarkBehavior.Watermark="ملاحظات الطلب" Margin="0,0,0,8" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4,0,0">
            <Button Content="💾 إضافة الطلب" Click="BtnSave_Click"
                    Width="140" Height="40"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource PrimaryBrush}" Foreground="White" />
            <Button Content="❌ إلغاء" Click="BtnCancel_Click"
                    Width="100" Height="40" Margin="12,0,0,0"
                    Style="{StaticResource PrimaryButton}" />
        </StackPanel>

        <!-- Existing items -->
        <Border x:Name="ExistingItemsPanel" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,12,0,0" Padding="8"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="عناصر الطلب الحالية" FontWeight="SemiBold" Margin="0,0,0,4" />
                <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="140">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*" />
                        <DataGridTextColumn Header="نوع السعر" Binding="{Binding PriceTypeDisplay}" Width="Auto" />
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalDisplay}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>