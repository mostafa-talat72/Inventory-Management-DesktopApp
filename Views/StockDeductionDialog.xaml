<UserControl x:Class="ProductApp.Views.StockDeductionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="500" MaxWidth="680">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackground}" Padding="28,24,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="16" Background="#FFEBEE">
                    <Path FlowDirection="LeftToRight" Width="26" Height="26" Fill="#C62828" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M19,13H5V11H19V13Z" />
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock x:Name="TxtTitle" Text="خصم من المخزون"
                               FontSize="21" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="اختر السبب وأدخل الكمية المراد خصمها"
                               FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,3,0,0" />
                </StackPanel>

                <!-- Close button -->
                <Button Grid.Column="2" Click="BtnCancel_Click" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C"
                                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        <Rectangle Grid.Row="0" Height="3" Fill="#C62828" Margin="28,0,28,0" VerticalAlignment="Bottom" />

        <!-- ═══════ PRODUCT INFO CARDS ═══════ -->
        <Border Grid.Row="1" CornerRadius="14" Background="{DynamicResource CardBackground}"
                Padding="16" Margin="28,16,28,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Product Name -->
                <Border Grid.Column="0" CornerRadius="10" Background="{DynamicResource SurfaceBackground}" Padding="14,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path FlowDirection="LeftToRight" Width="12" Height="12" Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                            <TextBlock Text="المنتج" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="5,0,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="TxtProductName" Text="" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource HeadingTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <!-- Current Stock -->
                <Border Grid.Column="2" CornerRadius="10" Background="{DynamicResource SurfaceBackground}" Padding="14,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path FlowDirection="LeftToRight" Width="12" Height="12" Fill="#2E7D32"
                                  Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                            <TextBlock Text="المخزون الحالي" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="5,0,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="TxtCurrentStock" Text="0" FontSize="15" FontWeight="Bold"
                                   Foreground="#2E7D32" />
                    </StackPanel>
                </Border>

                <!-- Stock After -->
                <Border Grid.Column="4" CornerRadius="10" Background="{DynamicResource SurfaceBackground}" Padding="14,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path FlowDirection="LeftToRight" Width="12" Height="12" Fill="#C62828"
                                  Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M19,13H5V11H19V13Z" />
                            <TextBlock Text="المتبقي بعد الخصم" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="5,0,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="TxtAfterStock" Text="-" FontSize="15" FontWeight="Bold"
                                   Foreground="#C62828" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ FORM ═══════ -->
        <Border Grid.Row="2" CornerRadius="14" Background="{DynamicResource CardBackground}"
                Padding="24,20" Margin="28,0,28,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#000" />
            </Border.Effect>
            <StackPanel>

                <!-- Reason -->
                <StackPanel Margin="0,0,0,22">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="24" Height="24" CornerRadius="12" Background="#C62828">
                            <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="سبب الخصم" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource HeadingTextBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>
                    <Border CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Background="{DynamicResource InputBackground}">
                        <ComboBox x:Name="CmbReason" SelectedIndex="0"
                                  Padding="12,0" FontSize="13" Height="46"
                                  BorderThickness="0" Background="Transparent"
                                  Foreground="{DynamicResource HeadingTextBrush}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                        <Border Width="12" Height="12" CornerRadius="6"
                                                Background="{Binding Color}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   Foreground="{DynamicResource HeadingTextBrush}"
                                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Border>
                    <!-- Cost recovery checkbox (visible only for ReturnToSupplier) -->
                    <Border x:Name="RecoveredBorder" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Background="{DynamicResource CardBackgroundAlt}"
                            Padding="14,10" Margin="0,14,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="ChkCostRecovered" VerticalAlignment="Center"
                                      Foreground="{DynamicResource HeadingTextBrush}" FontSize="13" FontWeight="SemiBold">
                                تم استرداد الثمن من المورد
                            </CheckBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Quantity -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="24" Height="24" CornerRadius="12" Background="#C62828">
                            <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="الكمية المراد خصمها" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource HeadingTextBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Carton -->
                        <Border x:Name="CartonBorder" Grid.Column="0" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Background="{DynamicResource CardBackgroundAlt}">
                            <StackPanel Margin="0,10,0,10">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#E8EAF6"
                                        HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#3F51B5"
                                          Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                                </Border>
                                <TextBlock x:Name="TxtCartonLabel" Text="كرتونة" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                                <Border CornerRadius="6" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" Background="{DynamicResource CardBackground}"
                                        Margin="8,0,8,0">
                                    <TextBox x:Name="TxtCartonQty" Text="0" TextAlignment="Center"
                                             FontSize="18" FontWeight="Bold" Padding="8,8"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="{DynamicResource HeadingTextBrush}"
                                             CaretBrush="{DynamicResource HeadingTextBrush}"
                                             PreviewTextInput="NumberOnly_PreviewTextInput"
                                             TextChanged="Qty_TextChanged" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Box -->
                        <Border x:Name="BoxBorder" Grid.Column="2" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Background="{DynamicResource CardBackgroundAlt}">
                            <StackPanel Margin="0,10,0,10">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#E0F2F1"
                                        HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#00897B"
                                          Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M20 6h-2.18c.07-.44.18-.88.18-1.35C18 2.53 15.47 0 12.35 0c-1.7 0-3.23.73-4.28 1.88L12 6.5l4-4.5C16.85 1.37 17.73 1 18.65 1 20.5 1 22 2.5 22 4.35c0 .95-.39 1.78-1 2.39V6zm-7.53 0L8 1.88C6.95.73 5.42 0 3.72 0 .6 0-1.93 2.53 1.65 4.65c0 .47.11.91.18 1.35H0L1 17h22L24 6h-2z" />
                                </Border>
                                <TextBlock x:Name="TxtBoxLabel" Text="علبة" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                                <Border CornerRadius="6" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" Background="{DynamicResource CardBackground}"
                                        Margin="8,0,8,0">
                                    <TextBox x:Name="TxtBoxQty" Text="0" TextAlignment="Center"
                                             FontSize="18" FontWeight="Bold" Padding="8,8"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="{DynamicResource HeadingTextBrush}"
                                             CaretBrush="{DynamicResource HeadingTextBrush}"
                                             PreviewTextInput="NumberOnly_PreviewTextInput"
                                             TextChanged="Qty_TextChanged" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Piece -->
                        <Border x:Name="PieceBorder" Grid.Column="4" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Background="{DynamicResource CardBackgroundAlt}">
                            <StackPanel Margin="0,10,0,10">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#F3E5F5"
                                        HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#7B1FA2"
                                          Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                                </Border>
                                <TextBlock x:Name="TxtPieceLabel" Text="قطعة" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                                <Border CornerRadius="6" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" Background="{DynamicResource CardBackground}"
                                        Margin="8,0,8,0">
                                    <TextBox x:Name="TxtPieceQty" Text="0" TextAlignment="Center"
                                             FontSize="18" FontWeight="Bold" Padding="8,8"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="{DynamicResource HeadingTextBrush}"
                                             CaretBrush="{DynamicResource HeadingTextBrush}"
                                             PreviewTextInput="NumberOnly_PreviewTextInput"
                                             TextChanged="Qty_TextChanged" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Warning message -->
                    <Border x:Name="WarningBorder" CornerRadius="8" Background="#FFEBEE"
                            BorderBrush="#FFCDD2" BorderThickness="1"
                            Padding="14,10" Margin="0,14,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#C62828"
                                  Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                            <TextBlock x:Name="TxtWarning" Text=""
                                       FontSize="12" FontWeight="SemiBold" Foreground="#C62828"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════ FOOTER ═══════ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="28,4,28,28">
            <Button Click="BtnSave_Click" Height="46" Padding="28,0" Cursor="Hand"
                    Background="#C62828" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White"
                                      Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M19,13H5V11H19V13Z" />
                                <TextBlock Text="تأكيد الخصم" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Click="BtnCancel_Click" Height="46" Padding="28,0" Cursor="Hand" Margin="14,0,0,0"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White"
                                      Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <TextBlock Text="إلغاء" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
