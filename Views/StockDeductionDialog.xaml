<UserControl x:Class="ProductApp.Views.StockDeductionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="460" MaxWidth="640">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="28,24,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="50" Height="50" CornerRadius="16" Background="#FFEBEE">
                    <Path Width="24" Height="24" Fill="#C62828" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M19,13H5V11H19V13Z" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock x:Name="TxtTitle" Text="خصم من المخزون" FontSize="22" FontWeight="Bold" Foreground="#1A237E" />
                    <TextBlock Text="اختر السبب وأدخل الكمية المراد خصمها" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                </StackPanel>

                <Button Grid.Column="2" Click="BtnCancel_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Height="3" Fill="#C62828" Margin="28,0,28,0" VerticalAlignment="Bottom" />

        <!-- Product info cards -->
        <Border Grid.Row="1" CornerRadius="14" Background="White" Padding="16" Margin="28,16,28,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.05" Color="#000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="10" Background="#F5F5FF" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="المخزون الحالي" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtCurrentStock" Text="0" FontSize="20" FontWeight="Bold" Foreground="#1A237E" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" CornerRadius="10" Background="#FFF8E1" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="المنتج" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtProductName" Text="" FontSize="20" FontWeight="Bold" Foreground="#37474F" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Form -->
        <Border Grid.Row="2" CornerRadius="14" Background="White" Padding="24,20" Margin="28,0,28,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.05" Color="#000" />
            </Border.Effect>
            <StackPanel>
                <!-- Reason -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="سبب الخصم" FontSize="13" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,0,8" />
                    <ComboBox x:Name="CmbReason" SelectedIndex="0"
                              Padding="10,8" FontSize="13" Height="42"
                              BorderBrush="#E0E0E0" BorderThickness="1"
                              Background="White">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="10" Height="10" CornerRadius="5"
                                            Background="{Binding Color}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontSize="13" Margin="10,4,0,4" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Quantity -->
                <StackPanel>
                    <TextBlock Text="الكمية" FontSize="13" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Margin="3" Background="#FAFAFA">
                            <StackPanel>
                                <TextBlock Text="كرتونة" FontSize="10" Foreground="#90A4AE" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                <TextBox x:Name="TxtCartonQty" Text="0" TextAlignment="Center"
                                         FontSize="16" FontWeight="Bold" Padding="8,6"
                                         BorderThickness="0" Background="Transparent"
                                         PreviewTextInput="NumberOnly_PreviewTextInput" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Margin="3" Background="#FAFAFA">
                            <StackPanel>
                                <TextBlock Text="علبة" FontSize="10" Foreground="#90A4AE" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                <TextBox x:Name="TxtBoxQty" Text="0" TextAlignment="Center"
                                         FontSize="16" FontWeight="Bold" Padding="8,6"
                                         BorderThickness="0" Background="Transparent"
                                         PreviewTextInput="NumberOnly_PreviewTextInput" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Margin="3" Background="#FAFAFA">
                            <StackPanel>
                                <TextBlock Text="قطعة" FontSize="10" Foreground="#90A4AE" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                <TextBox x:Name="TxtPieceQty" Text="0" TextAlignment="Center"
                                         FontSize="16" FontWeight="Bold" Padding="8,6"
                                         BorderThickness="0" Background="Transparent"
                                         PreviewTextInput="NumberOnly_PreviewTextInput" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="28,4,28,28">
            <Button Click="BtnSave_Click"
                    Height="44" Padding="28,0" Cursor="Hand"
                    Background="#C62828" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18" Height="18" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M19,13H5V11H19V13Z" />
                                <TextBlock Text="تأكيد الخصم" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Click="BtnCancel_Click"
                    Height="44" Padding="28,0" Cursor="Hand" Margin="14,0,0,0"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18" Height="18" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <TextBlock Text="إلغاء" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
