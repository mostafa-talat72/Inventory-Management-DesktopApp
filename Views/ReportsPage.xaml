<Page x:Class="ProductApp.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="التقارير"
      FlowDirection="RightToLeft"
      Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">

            <!-- Header -->
            <Border CornerRadius="16" Background="White" Padding="28,20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E8EAF6" Offset="0"/>
                                <GradientStop Color="#C5CAE9" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Width="24" Height="24" Fill="#1A237E" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="التقارير" FontSize="24" FontWeight="Bold" Foreground="#1A237E" />
                        <TextBlock Text="تحليل المبيعات والأرباح وإجمالي الإيرادات" FontSize="11" Foreground="#90A4AE" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Date Filter -->
            <Border CornerRadius="14" Background="White" Padding="24,18" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" Background="#E8EAF6" Margin="0,0,12,0">
                        <Path Width="16" Height="16" Fill="#3F51B5" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="من:" VerticalAlignment="Center" FontSize="12" Foreground="#78909C" Margin="0,0,8,0" />
                    <DatePicker x:Name="DateFrom" Grid.Column="1" Margin="30,0,0,0"
                                BorderBrush="#E0E0E0" BorderThickness="1" Height="38"
                                Background="White" FontSize="13" />
                    <TextBlock Grid.Column="2" Text="إلى:" VerticalAlignment="Center" FontSize="12" Foreground="#78909C" Margin="16,0,8,0" />
                    <DatePicker x:Name="DateTo" Grid.Column="3" Margin="22,0,0,0"
                                BorderBrush="#E0E0E0" BorderThickness="1" Height="38"
                                Background="White" FontSize="13" />
                    <Button Grid.Column="4" Click="ShowReport_Click"
                            Height="38" Padding="20,0" Cursor="Hand" Margin="16,0,0,0"
                            Background="#1A237E" Foreground="White" BorderThickness="0"
                            FontSize="13" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                                        <TextBlock Text="عرض التقرير" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.75" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnExport" Grid.Column="5" Click="Export_Click"
                            Height="38" Padding="14,0" Cursor="Hand" Margin="10,0,0,0"
                            Background="#37474F" Foreground="White" BorderThickness="0"
                            FontSize="13" FontWeight="SemiBold"
                            ToolTip="تصدير التقرير إلى CSV">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M12.9,14.5L15.8,10H13.5L11.7,13.2L10,10H7.7L10.6,14.5L7,19H9.3L11.7,15.3L14.1,19H16.4L12.9,14.5Z" />
                                        <TextBlock Text="CSV" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Summary Stats -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="14" Background="White" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#E8EAF6">
                            <Path Width="20" Height="20" Fill="#3F51B5" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="إجمالي المبيعات" FontSize="10" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtTotalSales" Text="0.00 ج.م" FontSize="22" FontWeight="Bold" Foreground="#1A237E" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="2" CornerRadius="14" Background="White" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#FFEBEE">
                            <Path Width="20" Height="20" Fill="#C62828" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M11 15h2v2h-2zm0-8h2v6h-2zm.99-5C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="إجمالي التكلفة" FontSize="10" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtTotalCost" Text="0.00 ج.م" FontSize="22" FontWeight="Bold" Foreground="#C62828" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="4" CornerRadius="14" Background="White" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#E8F5E9">
                            <Path Width="20" Height="20" Fill="#2E7D32" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="إجمالي الربح" FontSize="10" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtTotalProfit" Text="0.00 ج.م" FontSize="22" FontWeight="Bold" Foreground="#2E7D32" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="6" CornerRadius="14" Background="White" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#E0F2F1">
                            <Path Width="20" Height="20" Fill="#00695C" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="عدد الفواتير" FontSize="10" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtInvoiceCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="#00695C" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Profit Margin -->
            <Border x:Name="ProfitMarginCard" CornerRadius="14" Background="White" Padding="24,18" Margin="0,0,0,20"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" Background="#FFF3E0">
                        <TextBlock Text="%" FontSize="16" FontWeight="Bold" Foreground="#E65100"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="هامش الربح" FontSize="11" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtProfitMargin" Text="0%" FontSize="20" FontWeight="Bold" Foreground="#E65100" Margin="0,1,0,0" />
                    </StackPanel>
                    <Border x:Name="ProfitIndicator" Grid.Column="2" MinWidth="90" Padding="14,6" CornerRadius="8"
                            Background="#E8F5E9" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtProfitIndicator" Text="مربح" FontSize="12" FontWeight="Bold"
                                   Foreground="#2E7D32" HorizontalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- Period Comparison -->
            <Border x:Name="PeriodComparisonCard" CornerRadius="14" Background="White" Padding="24,20" Margin="0,0,0,20"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" Background="#E8EAF6">
                            <Path Width="16" Height="16" Fill="#3F51B5" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="مقارنة بالفترة السابقة" FontSize="14" FontWeight="Bold" Foreground="#37474F" />
                            <TextBlock x:Name="TxtComparisonPeriod" Text="" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="14,12" CornerRadius="10" Background="#F5F5FF">
                            <StackPanel>
                                <TextBlock Text="المبيعات" FontSize="10" Foreground="#90A4AE" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="TxtPrevSales" Text="0" FontSize="15" FontWeight="Bold" Foreground="#1A237E" />
                                    <Border x:Name="SalesChangeBadge" Margin="8,0,0,0" Padding="6,2" CornerRadius="4" Background="#E8F5E9">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="SalesArrow" Width="10" Height="10" Fill="#2E7D32" Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Data="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z" />
                                            <TextBlock x:Name="TxtSalesChange" Text="0%" FontSize="10" FontWeight="Bold" Foreground="#2E7D32" Margin="2,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Padding="14,12" CornerRadius="10" Background="#FFF5F5">
                            <StackPanel>
                                <TextBlock Text="التكلفة" FontSize="10" Foreground="#90A4AE" />
                                <TextBlock x:Name="TxtPrevCost" Text="0" FontSize="15" FontWeight="Bold" Foreground="#C62828" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Padding="14,12" CornerRadius="10" Background="#F1F8E9">
                            <StackPanel>
                                <TextBlock Text="الربح" FontSize="10" Foreground="#90A4AE" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="TxtPrevProfit" Text="0" FontSize="15" FontWeight="Bold" Foreground="#2E7D32" />
                                    <Border x:Name="ProfitChangeBadge" Margin="8,0,0,0" Padding="6,2" CornerRadius="4" Background="#E8F5E9">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="ProfitArrow" Width="10" Height="10" Fill="#2E7D32" Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Data="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z" />
                                            <TextBlock x:Name="TxtProfitChange" Text="0%" FontSize="10" FontWeight="Bold" Foreground="#2E7D32" Margin="2,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="6" Padding="14,12" CornerRadius="10" Background="#E0F2F1">
                            <StackPanel>
                                <TextBlock Text="الفواتير" FontSize="10" Foreground="#90A4AE" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="TxtPrevCount" Text="0" FontSize="15" FontWeight="Bold" Foreground="#00695C" />
                                    <Border x:Name="CountChangeBadge" Margin="8,0,0,0" Padding="6,2" CornerRadius="4" Background="#E8F5E9">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="CountArrow" Width="10" Height="10" Fill="#2E7D32" Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Data="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z" />
                                            <TextBlock x:Name="TxtCountChange" Text="0%" FontSize="10" FontWeight="Bold" Foreground="#2E7D32" Margin="2,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Invoice Status Distribution -->
            <Border CornerRadius="14" Background="White" Padding="24,20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" Background="#E8EAF6">
                            <Path Width="16" Height="16" Fill="#3F51B5" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="توزيع حالة الفواتير" FontSize="14" FontWeight="Bold" Foreground="#37474F" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="14,12" CornerRadius="10" Background="#E8F5E9">
                            <StackPanel>
                                <TextBlock Text="مدفوعة" FontSize="11" Foreground="#2E7D32" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtPaidCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#2E7D32" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Padding="14,12" CornerRadius="10" Background="#FFF8E1">
                            <StackPanel>
                                <TextBlock Text="مدفوعة جزئياً" FontSize="11" Foreground="#F57F17" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtPartialCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#F57F17" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Padding="14,12" CornerRadius="10" Background="#E3F2FD">
                            <StackPanel>
                                <TextBlock Text="مفتوحة" FontSize="11" Foreground="#1565C0" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtOpenCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#1565C0" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="6" Padding="14,12" CornerRadius="10" Background="#FFEBEE">
                            <StackPanel>
                                <TextBlock Text="ملغاة" FontSize="11" Foreground="#C62828" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtCancelledCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#C62828" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Top Products + Customer Analysis -->
            <Border CornerRadius="14" Background="White" Padding="0" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Top Products -->
                    <StackPanel Grid.Column="0" Margin="24,20,24,20">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#FFF3E0">
                                <Path Width="14" Height="14" Fill="#E65100" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="المنتجات الأكثر مبيعاً" FontSize="13" FontWeight="Bold" Foreground="#37474F" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </Grid>
                        <ItemsControl x:Name="TopProductsList" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="8" Background="{Binding RankBg}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                    Background="{Binding RankColor}" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Rank}" FontSize="10" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#37474F"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Height="4" CornerRadius="2" Background="#E0E0E0" Margin="0,4,0,0">
                                                    <Border Height="4" CornerRadius="2" Background="{Binding BarColor}"
                                                            HorizontalAlignment="Right"
                                                            Width="{Binding BarWidth}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding SalesDisplay}" FontSize="12" FontWeight="Bold"
                                                       Foreground="#1A237E" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border x:Name="EmptyTopProducts" Visibility="Visible" Padding="20,16" Background="#FAFAFA" CornerRadius="8">
                            <TextBlock Text="لا توجد مبيعات كافية" FontSize="11" Foreground="#B0BEC5" HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Column="1" Width="1" Background="#F0F0F0" />

                    <!-- Customer Analysis -->
                    <StackPanel Grid.Column="2" Margin="24,20,24,20">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#E8EAF6">
                                <Path Width="14" Height="14" Fill="#3F51B5" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="أفضل العملاء" FontSize="13" FontWeight="Bold" Foreground="#37474F" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </Grid>
                        <ItemsControl x:Name="TopCustomersList" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="8" Background="{Binding RankBg}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                                    Background="{Binding RankColor}">
                                                <TextBlock Text="{Binding Rank}" FontSize="10" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#37474F"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding InvoiceCount}" FontSize="10" Foreground="#90A4AE" Margin="0,1,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding SalesDisplay}" FontSize="12" FontWeight="Bold" Foreground="#1A237E" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border x:Name="EmptyTopCustomers" Visibility="Visible" Padding="20,16" Background="#FAFAFA" CornerRadius="8">
                            <TextBlock Text="لا توجد مبيعات كافية" FontSize="11" Foreground="#B0BEC5" HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Daily Sales Trend -->
            <Border x:Name="DailyTrendCard" CornerRadius="14" Background="White" Padding="0" Margin="0,0,0,20"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <StackPanel>
                    <Border Padding="24,20,24,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FAFAFE" Offset="0"/>
                                <GradientStop Color="#F5F5FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3F51B5" Offset="0"/>
                                            <GradientStop Color="#1A237E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Width="18" Height="18" Fill="White" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="المبيعات اليومية" FontSize="16" FontWeight="Bold" Foreground="#1A237E" />
                                    <TextBlock x:Name="TxtTrendSubtitle" Text="" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                                </StackPanel>
                                <Border Grid.Column="2" Padding="12,6" CornerRadius="8" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="10" Height="10" CornerRadius="3" Background="#3F51B5" VerticalAlignment="Center" />
                                        <TextBlock Text="الإيراد" FontSize="10" Foreground="#546E7A" Margin="5,0,12,0" VerticalAlignment="Center" />
                                        <Border Width="10" Height="10" CornerRadius="3" Background="#E53935" VerticalAlignment="Center" />
                                        <TextBlock Text="التكلفة" FontSize="10" Foreground="#546E7A" Margin="5,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Grid x:Name="TrendStatsGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Margin="0,0,4,0" Padding="10,8" CornerRadius="8" Background="#F5F5FF">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtTrendTotal" Text="0" FontSize="16" FontWeight="Bold" Foreground="#1A237E" HorizontalAlignment="Center" />
                                        <TextBlock Text="إجمالي الإيرادات" FontSize="9" Foreground="#90A4AE" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Margin="4,0,4,0" Padding="10,8" CornerRadius="8" Background="#FFF8E1">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtTrendAvg" Text="0" FontSize="16" FontWeight="Bold" Foreground="#F57F17" HorizontalAlignment="Center" />
                                        <TextBlock Text="متوسط اليوم" FontSize="9" Foreground="#BDBDBD" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Margin="4,0,4,0" Padding="10,8" CornerRadius="8" Background="#E8F5E9">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtTrendMax" Text="0" FontSize="16" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center" />
                                        <TextBlock Text="أعلى يوم" FontSize="9" Foreground="#A5D6A7" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Margin="4,0,0,0" Padding="10,8" CornerRadius="8" Background="#FFF3E0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtTrendMin" Text="0" FontSize="16" FontWeight="Bold" Foreground="#E65100" HorizontalAlignment="Center" />
                                        <TextBlock Text="أقل يوم" FontSize="9" Foreground="#FFCC80" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Padding="20,0,20,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#FAFAFA" CornerRadius="6" BorderBrush="#F0F0F0" BorderThickness="0,0,1,0">
                                <Canvas x:Name="AxisCanvas" />
                            </Border>
                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <Canvas x:Name="ChartCanvas" Height="230" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Detailed Report -->
            <Border CornerRadius="14" Background="White" Padding="0" Margin="0,0,0,4">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <StackPanel>
                    <!-- Grid Header -->
                    <Border Padding="24,20,24,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FAFAFE" Offset="0"/>
                                <GradientStop Color="#F5F5FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" Background="#E8EAF6">
                                <Path Width="16" Height="16" Fill="#3F51B5" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="تفاصيل المبيعات" FontSize="16" FontWeight="Bold" Foreground="#1A237E" />
                                <TextBlock Text="تقرير تفصيلي حسب المنتج" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                            </StackPanel>
                            <Border x:Name="ReportCountBadge" Grid.Column="2" Padding="12,5" CornerRadius="12"
                                    Background="#E8EAF6" VerticalAlignment="Center" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtReportCount" Text="0" FontSize="12" FontWeight="Bold" Foreground="#3F51B5" />
                                    <TextBlock Text="منتج" FontSize="12" Foreground="#5C6BC0" Margin="3,0,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Header Row -->
                    <Border Background="#1A237E">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="0.7*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="المنتج" Padding="16,12" Foreground="White" FontWeight="Bold" FontSize="11" />
                            <TextBlock Grid.Column="1" Text="الكمية" Padding="8,12" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="الإيراد" Padding="8,12" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="التكلفة" Padding="8,12" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="الربح" Padding="8,12" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="%" Padding="8,12" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" />
                        </Grid>
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <ItemsControl x:Name="ReportGrid" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,6" Background="White" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E8EAF6" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="0.7*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ProductName}" Padding="16,0,8,0"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#263238"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding CartonDisplay}" FontSize="10" Foreground="#546E7A" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding BoxDisplay}" FontSize="10" Foreground="#546E7A" HorizontalAlignment="Center" Margin="0,1,0,0" />
                                                <TextBlock Text="{Binding PieceDisplay}" FontSize="10" Foreground="#546E7A" HorizontalAlignment="Center" Margin="0,1,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding RetailRevDisplay}" FontSize="10" FontWeight="SemiBold" Foreground="#1A237E" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding WholesaleRevDisplay}" FontSize="10" FontWeight="SemiBold" Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding RetailCostDisplay}" FontSize="10" Foreground="#C62828" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding WholesaleCostDisplay}" FontSize="10" Foreground="#E53935" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="4" Text="{Binding ProfitDisplay}" FontSize="12" FontWeight="Bold"
                                                       Foreground="#2E7D32" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="5" Text="{Binding ProfitPercentDisplay}" FontSize="12" FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Totals Footer -->
                    <Border x:Name="ReportFooter" Background="#F5F5FF" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="0.7*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Padding="16,12" Background="#E8EAF6">
                                <TextBlock Text="الإجمالي" FontSize="13" FontWeight="Bold" Foreground="#1A237E" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtFooterCarton" Text="0" FontSize="10" FontWeight="SemiBold" Foreground="#37474F" HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtFooterBox" Text="0" FontSize="10" FontWeight="SemiBold" Foreground="#37474F" HorizontalAlignment="Center" Margin="0,1,0,0" />
                                <TextBlock x:Name="TxtFooterPiece" Text="0" FontSize="10" FontWeight="SemiBold" Foreground="#37474F" HorizontalAlignment="Center" Margin="0,1,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtFooterRetailRev" Text="0" FontSize="10" FontWeight="SemiBold" Foreground="#1A237E" HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtFooterWholesaleRev" Text="0" FontSize="10" FontWeight="SemiBold" Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtFooterRetailCost" Text="0" FontSize="10" FontWeight="SemiBold" Foreground="#C62828" HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtFooterWholesaleCost" Text="0" FontSize="10" FontWeight="SemiBold" Foreground="#E53935" HorizontalAlignment="Center" Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="4" x:Name="TxtFooterProfit" Text="0" FontSize="12" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" x:Name="TxtFooterMargin" Text="0" FontSize="12" Foreground="#37474F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <Border x:Name="EmptyState" Visibility="Visible" Padding="50,50" Background="Transparent">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="64" Height="64" CornerRadius="16" Background="#F5F5F5" Margin="0,0,0,0">
                                <Path Width="28" Height="28" Fill="#D0D0D0" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" />
                            </Border>
                            <TextBlock Text="لا توجد بيانات متاحة" FontSize="14" FontWeight="SemiBold" Foreground="#B0BEC5" Margin="0,16,0,4" HorizontalAlignment="Center" />
                            <TextBlock Text="اختر نطاق تاريخ ثم اضغط على عرض التقرير" FontSize="11" Foreground="#CFD8DC" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
