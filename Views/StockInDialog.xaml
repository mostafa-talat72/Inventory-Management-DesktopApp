<UserControl x:Class="ProductApp.Views.StockInDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wm="clr-namespace:ProductApp.Converters"
             FlowDirection="RightToLeft"
             MinWidth="750" MaxWidth="1150">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="32,24,32,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="50" Height="50" CornerRadius="16" Background="#E0F2F1">
                    <Path FlowDirection="LeftToRight" Width="24" Height="24" Fill="#00695C" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="إضافة مخزون" FontSize="22" FontWeight="Bold" Foreground="#1A237E" />
                        <Border Background="#00695C" CornerRadius="12" Padding="10,3"
                                Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtSelectedBadge" Text="0" FontSize="12" FontWeight="Bold" Foreground="White" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="اختر المنتجات ثم أدخل الكميات والتكلفة لكل منتج"
                               FontSize="11" Foreground="#90A4AE" Margin="0,2,0,0" />
                </StackPanel>

                <Button Grid.Column="2" Click="BtnCancel_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Height="3" Fill="#00897B" Margin="32,0,32,0" VerticalAlignment="Bottom" />

        <!-- Step 1: Product selection -->
        <Border Grid.Row="1" CornerRadius="14" Background="White" Padding="24,20" Margin="32,16,32,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000" />
            </Border.Effect>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Border Width="28" Height="28" CornerRadius="14" Background="#1A237E">
                        <TextBlock Text="1" FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="اختيار المنتجات" FontSize="15" FontWeight="SemiBold" Foreground="#37474F" VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>

                <Border CornerRadius="10" BorderBrush="#E8E8E8" BorderThickness="1" Background="#F8F9FA" Margin="0,0,0,14" Height="42">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Background="Transparent">
                            <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#B0BEC5" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                        </Border>
                        <TextBox x:Name="TxtSearch" Grid.Column="1"
                                 wm:WatermarkBehavior.Watermark="بحث عن منتج..."
                                 TextChanged="TxtSearch_TextChanged"
                                 Padding="8,0" BorderThickness="0"
                                 Background="Transparent" FontSize="13"
                                 VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <ItemsControl x:Name="ProductCards">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="190" Height="108" Margin="6" CornerRadius="14"
                                        Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                                        Cursor="Hand">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.05" Color="#000" />
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#00897B" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.14" Color="#00897B" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="14,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                                                   FontSize="14" FontWeight="Bold" Foreground="#1A237E"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Row="0" Grid.Column="1" CornerRadius="5" Background="#E8F5E9" Padding="7,2">
                                            <TextBlock Text="{Binding StockDisplay}" FontSize="9" Foreground="#2E7D32" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="{Binding UnitsDisplay}" FontSize="10" Foreground="#90A4AE"
                                                   VerticalAlignment="Center" Margin="0,6,0,0" />
                                    </Grid>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}" />
                                    </Border.InputBindings>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Divider -->
        <Border Grid.Row="2" Height="1" Background="#E8E8E8" Margin="32,0" />

        <!-- Step 2: Quantities and cost (card design) -->
        <Border Grid.Row="3" CornerRadius="14" Background="White" Padding="24,20" Margin="32,12,32,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000" />
            </Border.Effect>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Border Width="28" Height="28" CornerRadius="14" Background="#00897B">
                        <TextBlock Text="2" FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="الكميات والتكلفة" FontSize="15" FontWeight="SemiBold" Foreground="#37474F" VerticalAlignment="Center" Margin="10,0,0,0" />
                    <TextBlock x:Name="TxtSelectedCount" Text="(لا توجد منتجات محددة)" FontSize="11" Foreground="#90A4AE" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                    <ItemsControl x:Name="SelectedItemsList" Margin="0,0,0,8">
                        <ItemsControl.Resources>
                            <BooleanToVisibilityConverter x:Key="B2V" />
                        </ItemsControl.Resources>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" CornerRadius="8" Background="White"
                                        BorderBrush="#E8E8E8" BorderThickness="1">
                                    <Grid Margin="12,8,12,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Row 0: icon + name + total cost + remove -->
                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="5" Background="#E0F2F1">
                                            <Path FlowDirection="LeftToRight" Width="11" Height="11" Fill="#00695C" Stretch="Uniform"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding ProductName}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#37474F"
                                                   VerticalAlignment="Center" Margin="8,0,0,0" />

                                        <!-- Remove button -->
                                        <Button Grid.Column="2" Click="RemoveEntry_Click" Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" ToolTip="إزالة" Width="22" Height="22" VerticalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="b" Background="{TemplateBinding Background}"
                                                            CornerRadius="4" Padding="0">
                                                        <Path FlowDirection="LeftToRight" Width="11" Height="11" Fill="#E53935" Stretch="Uniform"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Data="M19,6.41L17.59,5 12,10.59 6.41,5 5,6.41 10.59,12 5,17.59 6.41,19 12,13.41 17.59,19 19,17.59 13.41,12 19,6.41Z" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="b" Property="Background" Value="#FFEBEE" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- Row 1: unit quantity boxes side by side -->
                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,6,0,0">
                                            <!-- Carton box -->
                                            <Border CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1"
                                                    Background="#FAFAFA" Padding="8,6"
                                                    Visibility="{Binding HasCarton, Converter={StaticResource B2V}}">
                                                <StackPanel>
                                                    <TextBlock Text="كرتونة" FontSize="10" Foreground="#78909C"
                                                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <Border CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1"
                                                            Background="White" Width="56" Height="24" Margin="0,4,0,0">
                                                        <TextBox Text="{Binding CartonQty, UpdateSourceTrigger=LostFocus}"
                                                                  FontSize="11" TextAlignment="Center"
                                                                  BorderThickness="0" Background="Transparent"
                                                                  VerticalAlignment="Center" Padding="2,0"
                                                                  PreviewTextInput="Qty_PreviewTextInput" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <!-- Box box -->
                                            <Border CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1"
                                                    Background="#FAFAFA" Padding="8,6" Margin="8,0,0,0"
                                                    Visibility="{Binding HasBox, Converter={StaticResource B2V}}">
                                                <StackPanel>
                                                    <TextBlock Text="علبة" FontSize="10" Foreground="#78909C"
                                                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <Border CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1"
                                                            Background="White" Width="56" Height="24" Margin="0,4,0,0">
                                                        <TextBox Text="{Binding BoxQty, UpdateSourceTrigger=LostFocus}"
                                                                  FontSize="11" TextAlignment="Center"
                                                                  BorderThickness="0" Background="Transparent"
                                                                  VerticalAlignment="Center" Padding="2,0"
                                                                  PreviewTextInput="Qty_PreviewTextInput" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <!-- Piece box -->
                                            <Border CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1"
                                                    Background="#FAFAFA" Padding="8,6" Margin="8,0,0,0"
                                                    Visibility="{Binding HasPiece, Converter={StaticResource B2V}}">
                                                <StackPanel>
                                                    <TextBlock Text="قطعة" FontSize="10" Foreground="#78909C"
                                                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <Border CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1"
                                                            Background="White" Width="56" Height="24" Margin="0,4,0,0">
                                                        <TextBox Text="{Binding PieceQty, UpdateSourceTrigger=LostFocus}"
                                                                  FontSize="11" TextAlignment="Center"
                                                                  BorderThickness="0" Background="Transparent"
                                                                  VerticalAlignment="Center" Padding="2,0"
                                                                  PreviewTextInput="Qty_PreviewTextInput" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <!-- Total cost box -->
                                            <Border CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1"
                                                    Background="#FFFDE7" Padding="8,6" Margin="12,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="التكلفة" FontSize="10" Foreground="#F57F17"
                                                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <Border CornerRadius="4" BorderBrush="#E8D5A0" BorderThickness="1"
                                                            Background="White" Width="80" Height="24" Margin="0,4,0,0">
                                                        <Grid>
                                                            <TextBox Text="{Binding TotalCost, StringFormat={}{0:0.##}, UpdateSourceTrigger=LostFocus}"
                                                                     FontSize="11" TextAlignment="Center" FontWeight="Bold"
                                                                     Foreground="#F57F17"
                                                                     BorderThickness="0" Background="Transparent"
                                                                     VerticalAlignment="Center" Padding="2,0" />
                                                            <TextBlock Text="ج.م" FontSize="8" Foreground="#B0BEC5"
                                                                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0" />
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="32,4,32,28">
            <Button Click="BtnSave_Click"
                    Height="44" Padding="28,0" Cursor="Hand"
                    Background="#00897B" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41L9,16.17Z" />
                                <TextBlock Text="حفظ الكل" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Click="BtnCancel_Click"
                    Height="44" Padding="28,0" Cursor="Hand" Margin="14,0,0,0"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <TextBlock Text="إلغاء" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
