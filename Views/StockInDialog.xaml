<UserControl x:Class="ProductApp.Views.StockInDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wm="clr-namespace:ProductApp.Converters"
             FlowDirection="RightToLeft"
             MinWidth="700" MaxWidth="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with accent bar -->
        <Border Grid.Row="0" Background="White" Padding="28,24,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14" Background="#E0F2F1">
                    <Path Width="22" Height="22" Fill="#00695C" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="إضافة مخزون" FontSize="22" FontWeight="Bold" Foreground="#1A237E" />
                        <Border Background="#00695C" CornerRadius="10" Padding="8,2"
                                Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtSelectedBadge" Text="0" FontSize="11" FontWeight="Bold" Foreground="White" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="اختر المنتجات ثم أدخل الكميات والتكلفة لكل منتج"
                               FontSize="11" Foreground="#90A4AE" Margin="0,2,0,0" />
                </StackPanel>

                <Button Grid.Column="2" Click="BtnCancel_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق"
                        VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Accent divider -->
        <Rectangle Grid.Row="0" Height="3" Fill="#00897B" Margin="28,0,28,0" VerticalAlignment="Bottom" />

        <!-- Step 1: Product selection -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="28,16,28,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="26" Height="26" CornerRadius="13" Background="#1A237E" Margin="0,0,8,0">
                        <TextBlock Text="1" FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="اختيار المنتجات" FontSize="14" FontWeight="SemiBold" Foreground="#37474F" VerticalAlignment="Center" />
                </StackPanel>

                <Border CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA" Margin="0,0,0,12">
                    <TextBox x:Name="TxtSearch"
                             wm:WatermarkBehavior.Watermark="بحث عن منتج..."
                             TextChanged="TxtSearch_TextChanged"
                             Padding="12,10" BorderThickness="0"
                             Background="Transparent" FontSize="13" />
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
                    <ItemsControl x:Name="ProductCards">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="185" Height="95" Margin="5" CornerRadius="12"
                                        Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                                        Cursor="Hand">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.06" Color="#000" />
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.14" Color="#1A237E" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="BorderBrush" Value="#1A237E" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                                                   FontSize="13" FontWeight="Bold" Foreground="#1A237E"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Row="0" Grid.Column="1" CornerRadius="4" Background="#E8F5E9" Padding="6,2">
                                            <TextBlock Text="{Binding StockDisplay}" FontSize="9" Foreground="#2E7D32" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="{Binding UnitsDisplay}" FontSize="11" Foreground="#90A4AE"
                                                   VerticalAlignment="Center" Margin="0,4,0,0" />
                                    </Grid>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}" />
                                    </Border.InputBindings>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Divider -->
        <Border Grid.Row="2" Height="1" Background="#E8E8E8" Margin="28,0" />

        <!-- Step 2: Quantities and cost -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="20" Margin="28,12,28,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="26" Height="26" CornerRadius="13" Background="#00897B" Margin="0,0,8,0">
                        <TextBlock Text="2" FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="الكميات والتكلفة" FontSize="14" FontWeight="SemiBold" Foreground="#37474F" VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtSelectedCount" Text="(لا توجد منتجات محددة)" FontSize="12" Foreground="#90A4AE" VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240">
                    <DataGrid x:Name="SelectedItemsGrid" AutoGenerateColumns="False"
                              AlternatingRowBackground="#F8F9FA"
                              BorderThickness="0" GridLinesVisibility="None"
                              MinHeight="80" Margin="0,0,0,8"
                              RowHeaderWidth="0" CanUserAddRows="False"
                              Background="Transparent"
                              HeadersVisibility="Column">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="42" />
                                <Setter Property="MinHeight" Value="42" />
                                <Setter Property="BorderBrush" Value="#F0F0F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Padding" Value="8,0" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Height" Value="36" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="Foreground" Value="#546E7A" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="8,0" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" IsReadOnly="True" Width="*" />
                            <DataGridTextColumn Header="كرتونة" Binding="{Binding CartonQty}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="علبة" Binding="{Binding BoxQty}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="قطعة" Binding="{Binding PieceQty}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="التكلفة الإجمالية" Binding="{Binding TotalCost, StringFormat={}{0:N2}}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Click="RemoveEntry_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" ToolTip="إزالة"
                                                Width="28" Height="28">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                                            CornerRadius="6" Padding="0">
                                                        <Path Width="14" Height="14" Fill="#E53935" Stretch="Uniform"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Data="M19,6.41L17.59,5 12,10.59 6.41,5 5,6.41 10.59,12 5,17.59 6.41,19 12,13.41 17.59,19 19,17.59 13.41,12 19,6.41Z" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#FFEBEE" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#FFCDD2" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="28,4,28,24">
            <Button Click="BtnSave_Click"
                    Height="40" Cursor="Hand" Padding="24,0"
                    Background="#00897B" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41L9,16.17Z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                حفظ الكل
            </Button>
            <Button Click="BtnCancel_Click"
                    Height="40" Cursor="Hand" Padding="24,0" Margin="12,0,0,0"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                إلغاء
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
