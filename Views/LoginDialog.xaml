<Window x:Class="ProductApp.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل الدخول - MTE Stock"
        Width="400" Height="440"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Background="#F0F2F5">
    <Window.Resources>
        <Style x:Key="LoginField" TargetType="PasswordBox">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
        </Style>
        <Style x:Key="LoginBtn" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>
    <Border CornerRadius="12" Background="White" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.15" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,24,0,0" HorizontalAlignment="Center">
                <Path Width="44" Height="44" Fill="#1A237E" Stretch="Uniform" HorizontalAlignment="Center"
                      Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z" />
                <TextBlock Text="MTE Stock" FontSize="28" FontWeight="Bold" Foreground="#1A237E" HorizontalAlignment="Center" Margin="0,8,0,0" />
                <TextBlock x:Name="TxtLocation" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center" Margin="0,2,0,0" />
            </StackPanel>

            <!-- Input -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="32,0">
                <TextBlock Text="الرجاء إدخال كلمة المرور" FontSize="13" Foreground="#546E7A" Margin="0,0,0,8" />
                <PasswordBox x:Name="TxtPassword" Style="{StaticResource LoginField}" KeyDown="TxtPassword_KeyDown" />
            </StackPanel>

            <!-- Button -->
            <StackPanel Grid.Row="2" Margin="32,0,32,0">
                <Button x:Name="BtnLogin" Click="BtnLogin_Click" Style="{StaticResource LoginBtn}" Background="#1A237E">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    دخول
                </Button>
            </StackPanel>

            <!-- Error Message -->
            <Border Grid.Row="3" x:Name="ErrorBorder" Visibility="Collapsed"
                    Background="#FFEBEE" BorderBrush="#EF9A9A" BorderThickness="1"
                    CornerRadius="8" Padding="10,8" Margin="32,10,32,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0" Width="16" Height="16" Fill="#E53935" Stretch="Uniform"
                          VerticalAlignment="Center" Margin="0,0,8,0"
                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                    <TextBlock x:Name="TxtError" Grid.Column="1" Text=""
                               FontSize="12" FontWeight="SemiBold" Foreground="#C62828"
                               VerticalAlignment="Center" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!-- Developer Signature -->
            <Border Grid.Row="4" Background="#F5F5F5" CornerRadius="0,0,12,12" Padding="0,10,0,12" Margin="0,14,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="تم تصميم وتطوير هذا النظام بواسطة"
                               FontSize="9" Foreground="#AAAAAA"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="المهندس مصطفى طلعت للحلول البرمجيه"
                               FontSize="10" FontWeight="Bold" Foreground="#888888"
                               HorizontalAlignment="Center" Margin="0,2,0,0" />
                    <TextBlock Text="01116626164"
                               FontSize="10" FontWeight="Bold" Foreground="#888888"
                               HorizontalAlignment="Center" Margin="0,1,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
