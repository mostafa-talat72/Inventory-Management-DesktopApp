<UserControl x:Class="ProductApp.Views.MergeInvoicesDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="620" MaxWidth="720">
    <Border CornerRadius="16" Background="{DynamicResource CardBackground}" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="24,20,24,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#7B1FA2" Offset="0" />
                        <GradientStop Color="#6A1B9A" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource CardBackground}" Opacity="0.2">
                        <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="White" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M19 8l-4 4h3c0 3.31-2.69 6-6 6-1.01 0-1.97-.25-2.8-.7l-1.46 1.46C8.97 19.54 10.43 20 12 20c4.42 0 8-3.58 8-8h3l-4-4zM6 12c0-3.31 2.69-6 6-6 1.01 0 1.97.25 2.8.7l1.46-1.46C15.03 4.46 13.57 4 12 4c-4.42 0-8 3.58-8 8H1l4 4 4-4H6z" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="دمج الفواتير" FontSize="20" FontWeight="Bold" Foreground="White" />
                        <TextBlock x:Name="TxtSubtitle" Text="" FontSize="11" Foreground="#CE93D8" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="2" Click="BtnCancel_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Width="32" Height="32"
                            ToolTip="إغلاق" VerticalAlignment="Top">
                        <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#CE93D8" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                    </Button>
                </Grid>
            </Border>

            <!-- ===== CUSTOMER INFO ===== -->
            <Border Grid.Row="1" Margin="24,16,24,0" CornerRadius="10" Background="{DynamicResource AppBackground}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#F3E5F5">
                        <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#7B1FA2" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M12 12c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm0-10c4.2 0 8 3.22 8 8.2 0 3.32-2.67 7.25-8 11.8-5.33-4.55-8-8.48-8-11.8C4 5.22 7.8 2 12 2z" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="TxtCustomerName" Text="" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HeadingTextBrush}" />
                        <TextBlock x:Name="TxtSelectionInfo" Text="لم يتم اختيار أي فاتورة" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,1,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="6" Background="#F3E5F5" Padding="10,4">
                            <TextBlock x:Name="TxtSelectedCount" Text="0" FontSize="11" FontWeight="Bold" Foreground="#7B1FA2" />
                        </Border>
                        <TextBlock Text="محدد" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== TARGET BADGE ===== -->
            <Border x:Name="TargetBadge" Grid.Row="2" Margin="24,10,24,0" CornerRadius="8" Background="#F3E5F5"
                    Padding="12,8" Visibility="Collapsed" BorderBrush="#CE93D8" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#7B1FA2" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                    <TextBlock x:Name="TxtTargetInfo" Text="" FontSize="12" FontWeight="Bold" Foreground="#7B1FA2" Margin="6,0,0,0" />
                    <TextBlock Text="(اضغط لتغيير الهدف)" FontSize="10" Foreground="#9C27B0" Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ===== FILTER BAR ===== -->
            <Border Grid.Row="3" Margin="24,10,24,0" CornerRadius="8" Background="{DynamicResource DividerBrush}" Padding="4" Height="34">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BtnAll" CornerRadius="6" Background="#7B1FA2" Padding="16,0" Height="26" Cursor="Hand" MouseLeftButtonDown="BtnAll_Click">
                            <TextBlock x:Name="TxtAll" Text="الكل" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                        </Border>
                        <Border x:Name="BtnUnpaid" CornerRadius="6" Background="Transparent" Padding="14,0" Height="26" Cursor="Hand" MouseLeftButtonDown="BtnUnpaid_Click" Margin="4,0,0,0">
                            <TextBlock x:Name="TxtUnpaid" Text="غير مدفوعة" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border x:Name="BtnPartiallyPaid" CornerRadius="6" Background="Transparent" Padding="14,0" Height="26" Cursor="Hand" MouseLeftButtonDown="BtnPartiallyPaid_Click" Margin="4,0,0,0">
                            <TextBlock x:Name="TxtPartiallyPaid" Text="مدفوعة جزئياً" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border x:Name="BtnPaid" CornerRadius="6" Background="Transparent" Padding="14,0" Height="26" Cursor="Hand" MouseLeftButtonDown="BtnPaid_Click" Margin="4,0,0,0">
                            <TextBlock x:Name="TxtPaid" Text="مدفوعة" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border x:Name="BtnCancelled" CornerRadius="6" Background="Transparent" Padding="14,0" Height="26" Cursor="Hand" MouseLeftButtonDown="BtnCancelled_Click" Margin="4,0,0,0">
                            <TextBlock x:Name="TxtCancelled" Text="ملغاة" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== INVOICE LIST ===== -->
            <Border Grid.Row="4" Margin="24,12,24,0" CornerRadius="10" Background="{DynamicResource CardBackgroundAlt}"
                    BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="InvoicesPanel" />
                </ScrollViewer>
            </Border>

            <!-- ===== HINT ===== -->
            <TextBlock x:Name="TxtHint" Grid.Row="4" Text="اختر فاتورتين أو أكثر للدمج"
                       FontSize="12" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center"
                       VerticalAlignment="Center" Margin="24,0" />

            <!-- ===== FOOTER ===== -->
            <Border Grid.Row="5" Background="{DynamicResource CardBackgroundAlt}" CornerRadius="0,0,16,16" Padding="24,16,24,20"
                    BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="BtnMerge" Click="BtnMerge_Click"
                                Height="40" Cursor="Hand" Padding="28,0"
                                Background="#6A1B9A" Foreground="White" BorderThickness="0"
                                FontSize="14" FontWeight="Bold" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#B0BEC5"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                                  Data="M19 8l-4 4h3c0 3.31-2.69 6-6 6-1.01 0-1.97-.25-2.8-.7l-1.46 1.46C8.97 19.54 10.43 20 12 20c4.42 0 8-3.58 8-8h3l-4-4zM6 12c0-3.31 2.69-6 6-6 1.01 0 1.97.25 2.8.7l1.46-1.46C15.03 4.46 13.57 4 12 4c-4.42 0-8 3.58-8 8H1l4 4 4-4H6z" />
                                            <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#6A1B9A" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            دمج
                        </Button>
                        <Button Click="BtnCancel_Click"
                                Height="40" Cursor="Hand" Padding="28,0" Margin="12,0,0,0"
                                Background="{DynamicResource CardBackgroundAlt}" Foreground="{DynamicResource BodyTextBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                FontSize="14" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource CardBackgroundAlt}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            إلغاء
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
