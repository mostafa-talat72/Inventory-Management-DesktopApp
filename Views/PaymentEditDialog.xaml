<UserControl x:Class="ProductApp.Views.PaymentEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wm="clr-namespace:ProductApp.Converters"
             FlowDirection="RightToLeft"
             MinWidth="420" MaxWidth="520">
    <Border CornerRadius="16" Background="{DynamicResource CardBackground}" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1565C0" CornerRadius="16,16,0,0" Padding="24,22,24,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource CardBackground}" Opacity="0.2">
                        <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="White" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock x:Name="TxtTitle" Text="تعديل الدفعة" FontSize="20" FontWeight="Bold" Foreground="White" />
                        <TextBlock x:Name="TxtSubtitle" Text="" FontSize="12" Foreground="#B0BEC5" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="24,22,24,0">
                <!-- Amount -->
                <TextBlock Text="المبلغ" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" Margin="0,0,0,4" />
                <Border CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=TxtAmount, Path=IsFocused}" Value="True">
                                    <Setter Property="BorderBrush" Value="#1565C0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <TextBox x:Name="TxtAmount" FontSize="18" FontWeight="SemiBold"
                                 Padding="12,10" BorderThickness="0" Background="Transparent"
                                 Foreground="{DynamicResource PrimaryTextBrush}" wm:WatermarkBehavior.Watermark="أدخل المبلغ"
                                 PreviewTextInput="TxtAmount_PreviewTextInput"
                                 DataObject.Pasting="TxtAmount_Pasting" />
                    </Grid>
                </Border>
                <TextBlock x:Name="TxtMaxHint" Text="" FontSize="10" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,4,0,0" />

                <!-- Payment Method -->
                <TextBlock Text="طريقة الدفع" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" Margin="0,16,0,4" />
                <Border CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4">
                    <ComboBox x:Name="CmbMethod" FontSize="14" Padding="8,6" BorderThickness="0" Background="Transparent">
                        <ComboBoxItem Content="نقدي" />
                        <ComboBoxItem Content="تحويل بنكي" />
                        <ComboBoxItem Content="محفظة الكترونية" />
                    </ComboBox>
                </Border>

                <!-- Date -->
                <TextBlock Text="تاريخ الدفع" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" Margin="0,16,0,4" />
                <Border CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4">
                    <DatePicker x:Name="DatePicker" FontSize="14" BorderThickness="0" Background="Transparent" />
                </Border>

                <!-- Notes -->
                <TextBlock Text="ملاحظات" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" Margin="0,16,0,4" />
                <Border CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0">
                    <TextBox x:Name="TxtNotes" FontSize="13" Padding="12,10" BorderThickness="0"
                             Background="Transparent" wm:WatermarkBehavior.Watermark="اختياري" />
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,24">
                <Button x:Name="BtnSave" Click="BtnSave_Click"
                        Height="42" Cursor="Hand" Padding="32,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                          Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" />
                                    <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    حفظ التعديلات
                </Button>
                <Button Click="BtnCancel_Click"
                        Height="42" Cursor="Hand" Padding="32,0" Margin="14,0,0,0"
                        Background="{DynamicResource CardBackgroundAlt}" Foreground="{DynamicResource BodyTextBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                        FontSize="14" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="10" Padding="{TemplateBinding Padding}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource CardBackgroundAlt}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    إلغاء
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
