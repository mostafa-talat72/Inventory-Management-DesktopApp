<UserControl x:Class="ProductApp.Views.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="360" MaxWidth="480">
    <Border CornerRadius="16" Background="White" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25" Color="#000000" />
        </Border.Effect>
        <StackPanel>
            <Border CornerRadius="16,16,0,0" Background="#FAFAFA" Padding="28,28">
                <Path FlowDirection="LeftToRight" x:Name="IconPath" Width="48" Height="48" Fill="#F57F17" Stretch="Uniform"
                      HorizontalAlignment="Center"
                      Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
            </Border>

            <StackPanel Margin="28,16,28,24">
                <TextBlock x:Name="TxtTitle" Text="تأكيد العملية"
                           FontSize="18" FontWeight="Bold" Foreground="#37474F"
                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                <TextBlock x:Name="TxtMessage" Text=""
                           FontSize="13" Foreground="#78909C"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           Margin="0,0,0,24" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnConfirm" Grid.Column="0"
                            Click="BtnConfirm_Click"
                            Height="42" Cursor="Hand"
                            Background="#C62828" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock x:Name="TxtConfirm" Text="نعم، تأكيد" FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center" />
                    </Button>
                    <Button x:Name="BtnCancel" Grid.Column="2"
                            Click="BtnCancel_Click"
                            Height="42" Cursor="Hand"
                            Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#EEEEEE" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E0E0E0" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="إلغاء" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#546E7A" HorizontalAlignment="Center" />
                    </Button>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
