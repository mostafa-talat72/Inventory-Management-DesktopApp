<UserControl x:Class="ProductApp.Views.SelectInvoiceDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="520" MaxWidth="620"
             MinHeight="380" MaxHeight="580">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackground}" Padding="28,24,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14" Background="{DynamicResource SurfaceBackground}">
                    <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="#F57F17" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock x:Name="TxtTitle" Text="فواتير غير مدفوعة" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock x:Name="TxtSubtitle" Text="" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,1,0,0" />
                </StackPanel>
                <Button Grid.Column="2" Click="BtnClose_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Accent divider -->
        <Rectangle Grid.Row="0" Height="3" Fill="#F57F17" Margin="28,0,28,0" VerticalAlignment="Bottom" />

        <!-- Info label -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackground}" Padding="28,16,28,0">
            <TextBlock x:Name="TxtInfo" Text=""
                       FontSize="13" Foreground="{DynamicResource BodyTextBrush}" TextWrapping="Wrap" />
        </Border>

        <!-- Invoice list + New invoice option -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackground}" Padding="28,14,28,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="اختر فاتورة للإضافة إليها" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,8" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="InvoiceListPanel" />
                </ScrollViewer>

                <!-- New Invoice option -->
                <Border Grid.Row="2" x:Name="NewInvoiceCard" CornerRadius="12"
                        Background="{DynamicResource SurfaceBackground}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="14,12" Margin="0,12,0,0"
                        Cursor="Hand" MouseLeftButtonDown="NewInvoiceCard_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#2E7D32">
                            <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="White" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="إنشاء فاتورة جديدة" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource HeadingTextBrush}" />
                            <TextBlock Text="فتح فاتورة جديدة بدون ربط بالفاتورة القديمة" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="6" Background="#2E7D32" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock Text="اختيار" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackground}" Padding="28,4,28,20">
            <Button Click="BtnClose_Click"
                    Height="40" Cursor="Hand" Padding="28,0"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold"
                    HorizontalAlignment="Left">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                إلغاء
            </Button>
        </Border>
    </Grid>
</UserControl>
