<UserControl x:Class="ProductApp.Views.ProductDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wm="clr-namespace:ProductApp.Converters"
             FlowDirection="RightToLeft"
             MinWidth="650" MaxWidth="950">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0">

            <!-- Header -->
            <Border Background="{DynamicResource CardBackground}" Padding="32,24,32,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="16" Background="#E8EAF6">
                        <Path FlowDirection="LeftToRight" Width="24" Height="24" Fill="#1A237E" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock x:Name="TxtHeader" Text="إضافة منتج جديد" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="أدخل بيانات المنتج ومستويات التعبئة والأسعار"
                                   FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0" />
                    </StackPanel>

                    <Button Grid.Column="2" Click="BtnCancel_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Width="36" Height="36"
                            ToolTip="إغلاق" VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="0">
                                    <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Accent divider -->
            <Rectangle Height="3" Fill="#1A237E" Margin="32,0,32,0" />

            <StackPanel Margin="32,24,32,28">

                <!-- Step: Basic Info -->
                <Border CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="24,20" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="28" Height="28" CornerRadius="14" Background="#1A237E">
                                <TextBlock Text="1" FontSize="13" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="المعلومات الأساسية" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HeadingTextBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>
                        <TextBox x:Name="TxtName" wm:WatermarkBehavior.Watermark="اسم المنتج *"
                                 Style="{StaticResource FormField}" FontSize="14" Height="42"
                                 Foreground="{DynamicResource HeadingTextBrush}"
                                 CaretBrush="{DynamicResource HeadingTextBrush}" />
                        <TextBox x:Name="TxtDescription" wm:WatermarkBehavior.Watermark="وصف المنتج (اختياري)"
                                 Style="{StaticResource FormField}" Margin="0,10,0,0" FontSize="14" Height="42"
                                 Foreground="{DynamicResource HeadingTextBrush}"
                                 CaretBrush="{DynamicResource HeadingTextBrush}" />
                    </StackPanel>
                </Border>

                <!-- Step: Piece Level -->
                <Border CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="24,20" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="28" Height="28" CornerRadius="14" Background="#1A237E">
                                <TextBlock Text="2" FontSize="13" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="القطعة" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HeadingTextBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <Border CornerRadius="4" Background="#E8EAF6" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="اختياري" FontSize="10" FontWeight="SemiBold" Foreground="#3F51B5" />
                            </Border>
                        </StackPanel>

                        <CheckBox x:Name="ChkHasPiece" Content="يوجد قطعة" FontWeight="SemiBold" Foreground="{DynamicResource HeadingTextBrush}"
                                  FontSize="13" Checked="ChkHasPiece_Checked" Unchecked="ChkHasPiece_Unchecked"
                                  Margin="0,0,0,14" />

                        <Border x:Name="PiecePanel" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                                Padding="16" Background="{DynamicResource SurfaceBackground}" IsEnabled="False" Opacity="0.5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0" Margin="3" Background="{DynamicResource CardBackgroundAlt}">
                                    <TextBox x:Name="TxtPieceName" Text="قطعة" FontSize="13"
                                             Padding="10,8" BorderThickness="0" Background="Transparent"
                                             Foreground="{DynamicResource HeadingTextBrush}"
                                             CaretBrush="{DynamicResource HeadingTextBrush}"
                                             HorizontalAlignment="Center" />
                                </Border>
                                <Border Grid.Column="1" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0" Margin="3" Background="{DynamicResource CardBackgroundAlt}">
                                    <TextBox x:Name="TxtPieceRetail" wm:WatermarkBehavior.Watermark="سعر القطاعي *"
                                             FontSize="13" Padding="10,8" BorderThickness="0"
                                             Background="Transparent" TextChanged="Price_TextChanged"
                                             Foreground="{DynamicResource HeadingTextBrush}"
                                             CaretBrush="{DynamicResource HeadingTextBrush}" />
                                </Border>
                                <Border Grid.Column="2" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0" Margin="3" Background="{DynamicResource CardBackgroundAlt}">
                                    <TextBox x:Name="TxtPieceWholesale" wm:WatermarkBehavior.Watermark="سعر الجملة"
                                             FontSize="13" Padding="10,8" BorderThickness="0"
                                             Background="Transparent" TextChanged="Price_TextChanged"
                                             Foreground="{DynamicResource HeadingTextBrush}"
                                             CaretBrush="{DynamicResource HeadingTextBrush}" />
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step: Box Level -->
                <Border CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="24,20" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="28" Height="28" CornerRadius="14" Background="#00897B">
                                <TextBlock Text="3" FontSize="13" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="العلبة" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HeadingTextBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <Border CornerRadius="4" Background="#E0F2F1" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="اختياري" FontSize="10" FontWeight="SemiBold" Foreground="#00897B" />
                            </Border>
                        </StackPanel>

                        <CheckBox x:Name="ChkHasBox" Content="يوجد علبة" FontWeight="SemiBold" Foreground="{DynamicResource HeadingTextBrush}"
                                  FontSize="13" Checked="ChkHasBox_Checked" Unchecked="ChkHasBox_Unchecked"
                                  Margin="0,0,0,14" />

                        <Border x:Name="BoxPanel" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                                Padding="16" Background="{DynamicResource SurfaceBackground}" IsEnabled="False" Opacity="0.5">
                            <StackPanel>
                                <TextBlock x:Name="TxtBoxUnitLabel" Text="العلبة تحتوي على: قطع" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition x:Name="BoxQtyCol" Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="6" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="0" Margin="2" Background="{DynamicResource CardBackground}">
                                        <TextBox x:Name="TxtBoxName" Text="علبة" FontSize="12"
                                                 Padding="8,6" BorderThickness="0" Background="Transparent"
                                                 Foreground="{DynamicResource HeadingTextBrush}"
                                                 CaretBrush="{DynamicResource HeadingTextBrush}"
                                                 HorizontalAlignment="Center" />
                                    </Border>
                                    <Border Grid.Column="1" CornerRadius="6" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="0" Margin="2" Background="{DynamicResource CardBackground}">
                                        <TextBox x:Name="TxtBoxQty" wm:WatermarkBehavior.Watermark="عدد القطع *"
                                                 FontSize="12" Padding="8,6" BorderThickness="0"
                                                 Background="Transparent" TextChanged="Qty_TextChanged"
                                                 Foreground="{DynamicResource HeadingTextBrush}"
                                                 CaretBrush="{DynamicResource HeadingTextBrush}" />
                                    </Border>
                                    <Border Grid.Column="2" CornerRadius="6" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="0" Margin="2" Background="{DynamicResource InputBackgroundAlt}">
                                        <TextBox x:Name="TxtBoxRetail" wm:WatermarkBehavior.Watermark="سعر القطاعي"
                                                 FontSize="12" Padding="8,6" BorderThickness="0"
                                                 Background="Transparent" TextChanged="Price_TextChanged"
                                                 Foreground="{DynamicResource HeadingTextBrush}"
                                                 CaretBrush="{DynamicResource HeadingTextBrush}" />
                                    </Border>
                                    <Border Grid.Column="3" CornerRadius="6" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="0" Margin="2" Background="{DynamicResource InputBackgroundAlt}">
                                        <TextBox x:Name="TxtBoxWholesale" wm:WatermarkBehavior.Watermark="سعر الجملة"
                                                 FontSize="12" Padding="8,6" BorderThickness="0"
                                                 Background="Transparent" TextChanged="Price_TextChanged"
                                                 Foreground="{DynamicResource HeadingTextBrush}"
                                                 CaretBrush="{DynamicResource HeadingTextBrush}" />
                                    </Border>
                                </Grid>
                                <TextBlock x:Name="TxtBoxHint" Text="* السعر يُحتسب تلقائياً من سعر القطعة × عدد القطع"
                                           FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="2,10,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step: Carton Level -->
                <Border CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="24,20" Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="28" Height="28" CornerRadius="14" Background="#00897B">
                                <TextBlock Text="4" FontSize="13" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="الكرتونة" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource HeadingTextBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <Border CornerRadius="4" Background="#E0F2F1" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="اختياري" FontSize="10" FontWeight="SemiBold" Foreground="#00897B" />
                            </Border>
                        </StackPanel>

                        <CheckBox x:Name="ChkHasCarton" Content="يوجد كرتونة" FontWeight="SemiBold" Foreground="{DynamicResource HeadingTextBrush}"
                                  FontSize="13" Checked="ChkHasCarton_Checked" Unchecked="ChkHasCarton_Unchecked"
                                  Margin="0,0,0,14" />

                        <Border x:Name="CartonPanel" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                                Padding="16" Background="{DynamicResource SurfaceBackground}" IsEnabled="False" Opacity="0.5">
                            <StackPanel>
                                <TextBlock x:Name="TxtCartonUnitLabel" Text="الكرتونة تحتوي على:" FontSize="12"
                                           FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition x:Name="CartonQtyCol" Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="6" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="0" Margin="2" Background="{DynamicResource CardBackground}">
                                        <TextBox x:Name="TxtCartonName" Text="كرتونة" FontSize="12"
                                                 Padding="8,6" BorderThickness="0" Background="Transparent"
                                                 Foreground="{DynamicResource HeadingTextBrush}"
                                                 CaretBrush="{DynamicResource HeadingTextBrush}"
                                                 HorizontalAlignment="Center" />
                                    </Border>
                                    <Border Grid.Column="1" CornerRadius="6" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="0" Margin="2" Background="{DynamicResource CardBackground}">
                                        <TextBox x:Name="TxtCartonQty" wm:WatermarkBehavior.Watermark="العدد *"
                                                 FontSize="12" Padding="8,6" BorderThickness="0"
                                                 Background="Transparent" TextChanged="Qty_TextChanged"
                                                 Foreground="{DynamicResource HeadingTextBrush}"
                                                 CaretBrush="{DynamicResource HeadingTextBrush}" />
                                    </Border>
                                    <Border Grid.Column="2" CornerRadius="6" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="0" Margin="2" Background="{DynamicResource InputBackgroundAlt}">
                                        <TextBox x:Name="TxtCartonRetail" wm:WatermarkBehavior.Watermark="سعر القطاعي"
                                                 FontSize="12" Padding="8,6" BorderThickness="0"
                                                 Background="Transparent" TextChanged="Price_TextChanged"
                                                 Foreground="{DynamicResource HeadingTextBrush}"
                                                 CaretBrush="{DynamicResource HeadingTextBrush}" />
                                    </Border>
                                    <Border Grid.Column="3" CornerRadius="6" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1" Padding="0" Margin="2" Background="{DynamicResource InputBackgroundAlt}">
                                        <TextBox x:Name="TxtCartonWholesale" wm:WatermarkBehavior.Watermark="سعر الجملة"
                                                 FontSize="12" Padding="8,6" BorderThickness="0"
                                                 Background="Transparent" TextChanged="Price_TextChanged"
                                                 Foreground="{DynamicResource HeadingTextBrush}"
                                                 CaretBrush="{DynamicResource HeadingTextBrush}" />
                                    </Border>
                                </Grid>
                                <TextBlock x:Name="TxtCartonHint" Text="* السعر يُحتسب تلقائياً"
                                           FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="2,10,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="BtnSave" Click="BtnSave_Click"
                            Height="44" Padding="28,0" Cursor="Hand"
                            Background="#1A237E" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Data="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41L9,16.17Z" />
                                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.75" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        حفظ
                    </Button>
                    <Button Click="BtnCancel_Click"
                            Height="44" Padding="28,0" Cursor="Hand" Margin="14,0,0,0"
                            Background="#78909C" Foreground="White" BorderThickness="0"
                            FontSize="14" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">إلغاء</TextBlock>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.75" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
