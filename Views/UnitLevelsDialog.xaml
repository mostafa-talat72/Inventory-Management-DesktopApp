<UserControl x:Class="ProductApp.Views.UnitLevelsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="650" MaxWidth="950">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0">

            <!-- Header -->
            <Border Background="{DynamicResource CardBackground}" Padding="32,24,32,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E8EAF6" Offset="0"/>
                                <GradientStop Color="#C5CAE9" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path FlowDirection="LeftToRight" Width="24" Height="24" Fill="#1A237E" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock x:Name="TxtHeader" Text="مستويات التعبئة" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock x:Name="TxtSubHeader" Text="" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0" />
                    </StackPanel>

                    <Button Grid.Column="2" Click="BtnCancel_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Width="36" Height="36"
                            ToolTip="إغلاق" VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="0">
                                    <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <Border Background="{DynamicResource CardBackground}" Padding="32,16,32,0">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnStockDeduction" Click="StockDeduction_Click"
                            Height="40" Padding="20,0" Cursor="Hand"
                            Background="#C62828" Foreground="White" BorderThickness="0"
                            FontSize="13" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Data="M19,13H5V11H19V13Z" />
                                        <TextBlock Text="خصم المخزون" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnStockMovement" Click="StockMovement_Click"
                            Height="40" Padding="20,0" Cursor="Hand" Margin="10,0,0,0"
                            Background="#F57F17" Foreground="White" BorderThickness="0"
                            FontSize="13" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" />
                                        <TextBlock Text="سجل المخزون" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnEdit" Click="EditProduct_Click"
                            Height="40" Padding="20,0" Cursor="Hand" Margin="10,0,0,0"
                            Background="#1A237E" Foreground="White" BorderThickness="0"
                            FontSize="13" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" />
                                        <TextBlock Text="تعديل المنتج" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Body -->
            <Border Background="{DynamicResource CardBackground}" Padding="32,20,32,28">
                <ItemsControl x:Name="UnitsCards" Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" MinHeight="130" Margin="0,0,14,12" CornerRadius="14"
                                    Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                                    Padding="18,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.04" Color="#000" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Border Width="36" Height="36" CornerRadius="10"
                                                Background="{Binding LevelColor}">
                                            <TextBlock Text="{Binding LevelIcon}" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource HeadingTextBrush}" />
                                            <TextBlock Text="{Binding UnitTypeDisplay}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Row="1" CornerRadius="5" Background="#E3F2FD" Margin="0,10,0,0"
                                            Padding="8,3" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ContainsDisplay}" FontSize="10"
                                                   Foreground="#1565C0" FontWeight="SemiBold" />
                                    </Border>

                                    <Grid Grid.Row="3" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="6" Background="{DynamicResource SurfaceBackground}" Padding="10,6" Margin="0,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="قطاعي" FontSize="9" Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock Text="{Binding RetailDisplay}"
                                                           FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" CornerRadius="6" Background="#F1F8E9" Padding="10,6" Margin="4,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="جملة" FontSize="9" Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock Text="{Binding WholesaleDisplay}"
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#2E7D32" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
