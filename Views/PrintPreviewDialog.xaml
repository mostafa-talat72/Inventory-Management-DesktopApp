<UserControl x:Class="ProductApp.Views.PrintPreviewDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="520" MaxWidth="560" Height="620">
    <Border CornerRadius="20" Background="White" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.3" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="28,20,28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#EDE7F6">
                    <Path Width="22" Height="22" Fill="#4527A0" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M18 8H6V6c0-2.21 1.79-4 4-4h4c2.21 0 4 1.79 4 4v2zm3 2v10c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V10c0-1.1.9-2 2-2h14c1.1 0 2 .9 2 2zm-6 5c0-.55-.45-1-1-1h-4c-.55 0-1 .45-1 1s.45 1 1 1h4c.55 0 1-.45 1-1z" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="معاينة الطباعة" FontSize="20" FontWeight="Bold" Foreground="#1A237E" />
                    <TextBlock x:Name="TxtPreviewInfo" Text="مراجعة الفاتورة قبل الطباعة" FontSize="12" Foreground="#90A4AE" Margin="0,2,0,0" />
                </StackPanel>
                <Border Grid.Column="2" Width="36" Height="36" CornerRadius="10" Background="#F5F5F5" Cursor="Hand" MouseLeftButtonDown="BtnCancel_Click">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Color="#000" />
                    </Border.Effect>
                    <Path Width="14" Height="14" Fill="#78909C" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                </Border>
            </Grid>

            <!-- Preview area -->
            <Border Grid.Row="1" Margin="28,16,28,0" CornerRadius="16" Background="#F0F2F5" Padding="20">
                <WebBrowser x:Name="ReceiptBrowser" />
            </Border>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="White" Padding="28,16,28,24" CornerRadius="0,0,20,20">
                <Border BorderThickness="0,1,0,0" BorderBrush="#F0F0F0" Padding="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnPrint" Grid.Column="0"
                                Click="BtnPrint_Click"
                                Height="48" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#1A237E" CornerRadius="12"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#283593" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#0D155B" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M18 8H6V6c0-2.21 1.79-4 4-4h4c2.21 0 4 1.79 4 4v2zm3 2v10c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V10c0-1.1.9-2 2-2h14c1.1 0 2 .9 2 2zm-6 5c0-.55-.45-1-1-1h-4c-.55 0-1 .45-1 1s.45 1 1 1h4c.55 0 1-.45 1-1z" />
                                <TextBlock Grid.Column="1" Text="  طباعة" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button x:Name="BtnPdf" Grid.Column="2"
                                Click="BtnPdf_Click"
                                Height="48" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#2E7D32" CornerRadius="12"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#388E3C" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1B5E20" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M20 2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8.5 7.5c0 .83-.67 1.5-1.5 1.5H9v2H7.5V7H10c.83 0 1.5.67 1.5 1.5v1zm5 2c0 .83-.67 1.5-1.5 1.5h-2.5V7H15c.83 0 1.5.67 1.5 1.5v3zm4-3H19v1h1.5V11H19v2h-1.5V7h3v1.5zM9 9.5h1v-1H9v1zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm10 5.5h1v-3h-1v3z" />
                                <TextBlock Grid.Column="1" Text="  تصدير PDF" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button x:Name="BtnCancel" Grid.Column="4"
                                Click="BtnCancel_Click"
                                Height="48" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#F5F5F5" CornerRadius="12"
                                            BorderBrush="#E0E0E0" BorderThickness="1"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#EEEEEE" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E0E0E0" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="إلغاء" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#546E7A" HorizontalAlignment="Center" Margin="20,0" />
                        </Button>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
