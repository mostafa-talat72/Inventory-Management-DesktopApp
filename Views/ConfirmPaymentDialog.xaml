<UserControl x:Class="ProductApp.Views.ConfirmPaymentDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="360" MaxWidth="480">
    <Border CornerRadius="16" Background="White" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.25" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Icon & Header -->
            <Border Grid.Row="0" Background="#2E7D32" CornerRadius="16,16,0,0" Padding="24,22,24,18">
                <StackPanel>
                    <Border Width="48" Height="48" CornerRadius="24" Background="White" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Path Width="24" Height="24" Fill="#2E7D32" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                    </Border>
                    <TextBlock x:Name="TxtTitle" Text="تأكيد دفع الفاتورة" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="28,22,28,0">
                <TextBlock x:Name="TxtMessage" Text="" FontSize="14" Foreground="#37474F" TextWrapping="Wrap" LineHeight="24" />
                <Border Margin="0,18,0,0" CornerRadius="10" Background="#E8F5E9" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="المبلغ المتبقي" FontSize="12" Foreground="#2E7D32" VerticalAlignment="Center" />
                        <TextBlock x:Name="TxtAmount" Grid.Column="1" FontSize="20" FontWeight="Bold" Foreground="#1B5E20" />
                    </Grid>
                </Border>

                <!-- Payment Method -->
                <TextBlock Text="طريقة الدفع" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,16,0,4" />
                <Border CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="4">
                    <ComboBox x:Name="CmbMethod" FontSize="14" Padding="8,6" BorderThickness="0" Background="Transparent">
                        <ComboBoxItem Content="نقدي" IsSelected="True" />
                        <ComboBoxItem Content="تحويل بنكي" />
                        <ComboBoxItem Content="محفظة الكترونية" />
                    </ComboBox>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,24">
                <Button x:Name="BtnConfirm" Click="BtnConfirm_Click"
                        Height="44" Cursor="Hand" Padding="28,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="18" Height="18" Fill="White" Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                                    <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    تأكيد الدفع
                </Button>
                <Button Click="BtnCancel_Click"
                        Height="44" Cursor="Hand" Padding="28,0"
                        Background="#F5F5F5" Foreground="#546E7A" BorderThickness="1" BorderBrush="#E0E0E0"
                        FontSize="14" FontWeight="SemiBold" Margin="14,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="10" Padding="{TemplateBinding Padding}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#EEEEEE" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E0E0E0" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    إلغاء
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
