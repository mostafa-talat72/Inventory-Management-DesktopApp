<UserControl x:Class="ProductApp.Views.ManageOrdersDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="700" MaxWidth="1100" MaxHeight="640">
    <Border CornerRadius="16" Background="White" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#00897B" CornerRadius="16,16,0,0" Padding="24,18,24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Background="White" Opacity="0.2">
                        <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="White" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock x:Name="TxtTitle" Text="إدارة الطلبات" FontSize="20" FontWeight="Bold" Foreground="White" />
                        <TextBlock x:Name="TxtSubtitle" Text="" FontSize="11" Foreground="#80CBC4" Margin="0,1,0,0" />
                    </StackPanel>
                    <Button Grid.Column="2" Click="BtnClose_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Width="32" Height="32"
                            ToolTip="إغلاق" VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="0">
                                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#B0BEC5" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FFFFFF22" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Summary bar -->
            <Border Grid.Row="1" Padding="24,14,24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtInfo" Grid.Column="0" Text="" FontSize="13" Foreground="#546E7A" VerticalAlignment="Center" />
                    <Border Grid.Column="1" CornerRadius="8" Background="#E0F2F1" Padding="14,8" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="إجمالي الفاتورة: " FontSize="12" Foreground="#00695C" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtTotal" Text="0 ج.م" FontSize="14" FontWeight="Bold" Foreground="#004D40" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Items list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="24,10,24,0" Padding="0,0,0,4">
                <StackPanel x:Name="ItemsPanel" />
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,20">
                <Button Click="BtnClose_Click"
                        Height="42" Cursor="Hand" Padding="36,0"
                        Background="#00897B" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z" />
                                    <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    تم
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
