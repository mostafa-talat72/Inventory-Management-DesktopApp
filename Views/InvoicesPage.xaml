<Page x:Class="ProductApp.Views.InvoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wm="clr-namespace:ProductApp.Converters"
      xmlns:converters="clr-namespace:ProductApp.Converters"
      Title="الفواتير"
      FlowDirection="RightToLeft"
      Background="#F0F2F5">
    <Page.Resources>
        <converters:InvoiceStatusToColorConverter x:Key="StatusColorConverter" />
        <converters:PriceTypeConverter x:Key="PriceTypeConverter" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Customer Context -->
        <Border x:Name="CustomerContextPanel" Grid.Row="0" Background="#E8EAF6" CornerRadius="8" Padding="16" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="👤" FontSize="28" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0">
                    <TextBlock x:Name="TxtCustomerContextName" FontSize="20" FontWeight="Bold" Foreground="#1A237E" />
                    <TextBlock x:Name="TxtCustomerContextInfo" FontSize="13" Foreground="#546E7A" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="2" Content="+ إضافة طلب للعميل" Click="AddOrderForCustomer_Click"
                        Style="{StaticResource PrimaryButton}" Background="{StaticResource PrimaryBrush}" Foreground="White"
                        Height="40" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Invoice List -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="الفواتير" Style="{StaticResource SectionTitle}" />
                    <TextBox x:Name="SearchBox"
                             wm:WatermarkBehavior.Watermark="بحث برقم الفاتورة أو اسم العميل"
                             TextChanged="SearchBox_TextChanged" Padding="8" Margin="0,0,0,8" />

                    <ListBox x:Name="InvoiceList"
                             SelectionChanged="InvoiceList_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" Height="500">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,8" Margin="0,2" CornerRadius="6"
                                        BorderBrush="{Binding StatusColor, Converter={StaticResource StatusColorConverter}}"
                                        BorderThickness="0,0,4,0" Background="White">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayText}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding RemainingDisplay}" FontSize="12" Foreground="#78909C" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="+ فاتورة نقدي" Click="AddCashInvoice_Click"
                            Margin="0,8,0,0"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Border>

            <!-- Invoice Detail -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="16" Margin="8,0,0,0">
                <Grid>
                    <StackPanel x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtInvoiceHeader" Grid.Column="0" FontSize="20" FontWeight="Bold" Foreground="#1A237E" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="🖨️ طباعة" Click="PrintInvoice_Click"
                                    Style="{StaticResource PrimaryButton}" Background="#00897B"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="الإجمالي" FontSize="12" Foreground="#78909C" />
                                <TextBlock x:Name="TxtTotal" FontSize="18" FontWeight="Bold" Foreground="#1A237E" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="المدفوع" FontSize="12" Foreground="#78909C" />
                                <TextBlock x:Name="TxtPaid" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="المتبقي" FontSize="12" Foreground="#78909C" />
                                <TextBlock x:Name="TxtRemaining" FontSize="18" FontWeight="Bold" Foreground="#C62828" />
                            </StackPanel>
                        </Grid>

                        <TabControl Margin="0,12,0,0">
                            <TabItem Header="الطلبات">
                                <StackPanel>
                                    <Button Content="+ إضافة طلب" Click="AddOrder_Click"
                                            Margin="0,0,0,8" HorizontalAlignment="Left"
                                            Style="{StaticResource PrimaryButton}" />
                                    <DataGrid x:Name="OrdersGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                              Height="250" AlternatingRowBackground="#F5F5F5">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="2*" />
                                            <DataGridTextColumn Header="النوع" Binding="{Binding PriceTypeDisplay}" Width="*" />
                                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalDisplay}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="المدفوعات">
                                <StackPanel>
                                    <Button Content="دفع الفاتورة كاملة" Click="AddPayment_Click"
                                            Margin="0,0,0,8" HorizontalAlignment="Left"
                                            Style="{StaticResource PrimaryButton}" />
                                    <DataGrid x:Name="PaymentsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                              Height="250" AlternatingRowBackground="#F5F5F5">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="التاريخ" Binding="{Binding PaymentDateDisplay}" Width="*" />
                                            <DataGridTextColumn Header="المبلغ" Binding="{Binding AmountDisplay}" Width="*" />
                                            <DataGridTextColumn Header="الطريقة" Binding="{Binding PaymentMethod}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>

                    <TextBlock x:Name="NoSelectionText" Text="اختر فاتورة لعرض التفاصيل"
                               FontSize="16" Foreground="#90A4AE" HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>