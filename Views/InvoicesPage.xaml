<Page x:Class="ProductApp.Views.InvoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="كل الفواتير"
      FlowDirection="RightToLeft"
      Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="28,24,28,16" CornerRadius="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14" Background="#E8EAF6">
                    <Path Width="22" Height="22" Fill="#1A237E" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="كل الفواتير" FontSize="22" FontWeight="Bold" Foreground="#1A237E" />
                    <TextBlock Text="جميع فواتير العملاء والنقدي" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Summary cards -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="10" Background="#F0F0FF" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="عدد الفواتير" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtInvoiceCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#1A237E" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" CornerRadius="10" Background="#E8F5E9" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="إجمالي المشتريات" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtTotalAmount" Text="0 ج.م" FontSize="20" FontWeight="Bold" Foreground="#2E7D32" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" CornerRadius="10" Background="#E3F2FD" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="المدفوع" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtPaidAmount" Text="0 ج.م" FontSize="20" FontWeight="Bold" Foreground="#1565C0" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="6" CornerRadius="10" Background="#FFF3E0" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="المتبقي" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtRemainingAmount" Text="0 ج.م" FontSize="20" FontWeight="Bold" Foreground="#E65100" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Filter bar + search + sort -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="قائمة الفواتير" FontSize="15" FontWeight="SemiBold" Foreground="#37474F" VerticalAlignment="Center" Margin="12,0,0,0" />
                    <Border Grid.Column="1" CornerRadius="8" Background="#F0F0F0" Padding="4,0" Height="36" HorizontalAlignment="Left">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="BtnUnpaid" CornerRadius="6" Background="#1565C0" Padding="16,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnUnpaid_Click">
                                    <TextBlock x:Name="TxtUnpaid" Text="غير مدفوعة" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                                </Border>
                                <Border x:Name="BtnPartiallyPaid" CornerRadius="6" Background="Transparent" Padding="14,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnPartiallyPaid_Click" Margin="4,0,0,0">
                                    <TextBlock x:Name="TxtPartiallyPaid" Text="مدفوعة جزئياً" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" VerticalAlignment="Center" />
                                </Border>
                                <Border x:Name="BtnCancelled" CornerRadius="6" Background="Transparent" Padding="14,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnCancelled_Click" Margin="4,0,0,0">
                                    <TextBlock x:Name="TxtCancelled" Text="ملغاة" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" VerticalAlignment="Center" />
                                </Border>
                                <Border x:Name="BtnPaid" CornerRadius="6" Background="Transparent" Padding="14,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnPaid_Click" Margin="4,0,0,0">
                                    <TextBlock x:Name="TxtPaid" Text="مدفوعة بالكامل" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" VerticalAlignment="Center" />
                                </Border>
                                <Border x:Name="BtnAll" CornerRadius="6" Background="Transparent" Padding="16,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnAll_Click" Margin="4,0,0,0">
                                    <TextBlock x:Name="TxtAll" Text="كل الفواتير" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                        <Border x:Name="BtnSort" CornerRadius="6" Background="#F0F0F0" Padding="10,0" Height="36" Cursor="Hand" MouseLeftButtonDown="BtnSort_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path x:Name="SortIcon" Width="16" Height="16" Fill="#546E7A" Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z" />
                                <TextBlock x:Name="TxtSort" Text="الأحدث" FontSize="11" Foreground="#546E7A" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="1" Margin="0,8,0,0" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Height="32">
                    <Grid>
                        <TextBox x:Name="TxtSearch" FontSize="12" Padding="10,0" BorderThickness="0"
                                 Background="Transparent" Foreground="#37474F"
                                 TextChanged="TxtSearch_TextChanged" VerticalAlignment="Center" />
                        <TextBlock IsHitTestVisible="False" Text="بحث برقم الفاتورة..." FontSize="12"
                                   Foreground="#B0BEC5" VerticalAlignment="Center" Margin="12,0,0,0"
                                   x:Name="SearchWatermark" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Batch action bar -->
        <Border x:Name="BatchBar" Grid.Row="3" Margin="0,0,0,8" CornerRadius="8" Background="#F3E5F5"
                Padding="12,8" Visibility="Collapsed" BorderBrush="#CE93D8" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="6" Background="#E1BEE7" Padding="10,4" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtBatchCount" Text="0" FontSize="12" FontWeight="Bold" Foreground="#6A1B9A" />
                </Border>
                <TextBlock Grid.Column="1" Text="محددة" FontSize="11" Foreground="#7B1FA2" VerticalAlignment="Center" Margin="6,0,0,0" />
                <Border Grid.Column="2" CornerRadius="6" Background="#546E7A" Padding="10,6" Cursor="Hand" Margin="0,0,6,0" MouseLeftButtonDown="BatchPrint_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="14" Height="14" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                              Data="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z" />
                        <TextBlock Text="طباعة المحدد" FontSize="11" FontWeight="Bold" Foreground="White" Margin="4,0,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" CornerRadius="6" Background="#C62828" Padding="10,6" Cursor="Hand" MouseLeftButtonDown="BatchClear_Click">
                    <TextBlock Text="إلغاء التحديد" FontSize="11" FontWeight="Bold" Foreground="White" />
                </Border>
            </Grid>
        </Border>

        <!-- Invoice cards list -->
        <StackPanel x:Name="InvoicesPanel" Grid.Row="4" />

        <!-- Show more -->
        <Border x:Name="ShowMoreBar" Grid.Row="5" Margin="0,8,0,0" CornerRadius="8" Background="#F5F5F5"
                Padding="12,10" Cursor="Hand" MouseLeftButtonDown="ShowMore_Click"
                Visibility="Collapsed" BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Path Width="16" Height="16" Fill="#546E7A" Stretch="Uniform" VerticalAlignment="Center"
                      Data="M7 10l5 5 5-5z" />
                <TextBlock x:Name="TxtShowMore" Text="عرض المزيد" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="6,0,0,0" />
            </StackPanel>
        </Border>
        </Grid>
    </ScrollViewer>
</Page>
