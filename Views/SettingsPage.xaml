<UserControl x:Class="ProductApp.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardHeader" TargetType="Border">
            <Setter Property="CornerRadius" Value="12,12,0,0" />
            <Setter Property="Padding" Value="24,14" />
            <Setter Property="MinHeight" Value="56" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#546E7A" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="SettingsInput" TargetType="Control">
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecBtn" TargetType="Button" BasedOn="{StaticResource SaveBtn}">
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="Foreground" Value="#546E7A" />
        </Style>
        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#37474F" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SettingsCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F7FA">
        <StackPanel Margin="40" MaxWidth="720">

            <!-- Page Header -->
            <Border CornerRadius="16" Background="White" Padding="28,20" Margin="0,0,0,28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E8EAF6" Offset="0"/>
                                <GradientStop Color="#C5CAE9" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Width="24" Height="24" Fill="#1A237E" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="الإعدادات" FontSize="22" FontWeight="Bold" Foreground="#1A237E" />
                        <TextBlock Text="تخصيص إعدادات النظام وإدارة النسخ الاحتياطية" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== LOCATION ==================== -->
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardHeader}" Background="#E8EAF6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1A237E" VerticalAlignment="Center">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock Text="اسم المكان" FontSize="15" FontWeight="Bold" Foreground="#1A237E" />
                                <TextBlock Text="اسم المنشأة أو الفرع" FontSize="11" Foreground="#7986CB" Margin="0,1,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="24,20,24,24">
                        <TextBlock Text="اسم المكان" Style="{StaticResource FieldLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="8" Padding="2" Grid.Column="0">
                                <TextBox x:Name="TxtLocationName" Height="36" FontSize="13" BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" />
                            </Border>
                            <Button x:Name="BtnSaveLocation" Click="BtnSaveLocation_Click" Grid.Column="1"
                                    Background="#1A237E" Style="{StaticResource SaveBtn}" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="14" Height="14" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                          Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                                    <TextBlock Text="  حفظ" Margin="4,0,0,0" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== PASSWORD ==================== -->
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardHeader}" Background="#FFF3E0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" CornerRadius="8" Background="#E65100" VerticalAlignment="Center">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                 <TextBlock Text="كلمة المرور" FontSize="15" FontWeight="Bold" Foreground="#E65100" />
                                <TextBlock Text="تغيير كلمة المرور الخاصة بالنظام" FontSize="11" Foreground="#FFA726" Margin="0,1,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="24,20,24,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                 <TextBlock Text="كلمة المرور الحاليه" Style="{StaticResource FieldLabel}" />
                                <Border BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="8" Padding="2">
                                    <PasswordBox x:Name="TxtCurrentPassword" Height="36" FontSize="13" BorderThickness="0" Padding="10,0" />
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0">
                                 <TextBlock Text="كلمة المرور الجديده" Style="{StaticResource FieldLabel}" />
                                <Border BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="8" Padding="2">
                                    <PasswordBox x:Name="TxtNewPassword" Height="36" FontSize="13" BorderThickness="0" Padding="10,0" />
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                 <TextBlock Text="تأكيد كلمة المرور الجديده" Style="{StaticResource FieldLabel}" />
                                <Border BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="8" Padding="2">
                                    <PasswordBox x:Name="TxtConfirmPassword" Height="36" FontSize="13" BorderThickness="0" Padding="10,0" />
                                </Border>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="TxtPasswordError" FontSize="11" Foreground="#E53935" Visibility="Collapsed" Margin="0,8,0,0" />
                        <Button x:Name="BtnChangePassword" Click="BtnChangePassword_Click" Background="#E65100" Style="{StaticResource SaveBtn}" HorizontalAlignment="Left" Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="14" Height="14" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2z" />
                                 <TextBlock Text="  تغيير كلمة المرور" Margin="4,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== BACKUP ==================== -->
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardHeader}" Background="#E8F5E9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" CornerRadius="8" Background="#2E7D32" VerticalAlignment="Center">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock Text="النسخ الاحتياطي" FontSize="15" FontWeight="Bold" Foreground="#2E7D32" />
                                <TextBlock Text="حماية البيانات بنسخ احتياطية منتظمة" FontSize="11" Foreground="#66BB6A" Margin="0,1,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="24,20,24,24">

                        <!-- Backup Folder -->
                        <TextBlock Text="مجلد النسخ الاحتياطي" Style="{StaticResource FieldLabel}" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="8" Padding="2" Grid.Column="0">
                                <TextBox x:Name="TxtBackupFolder" Height="36" FontSize="13" BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" IsReadOnly="True" Background="#FAFAFA" />
                            </Border>
                            <Button x:Name="BtnBrowseFolder" Click="BtnBrowseFolder_Click" Grid.Column="1" Style="{StaticResource SecBtn}" Margin="8,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="14" Height="14" Fill="#546E7A" Stretch="Uniform" VerticalAlignment="Center"
                                          Data="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z" />
                                    <TextBlock Text="  استعراض" Margin="4,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnBackupNow" Click="BtnBackupNow_Click" Grid.Column="2" Background="#2E7D32" Style="{StaticResource SaveBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="14" Height="14" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                          Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z" />
                                    <TextBlock Text="  نسخ احتياطي الآن" Margin="4,0,0,0" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Backup Status Card -->
                        <Border Background="#F5F7FA" CornerRadius="8" Padding="14,12" Margin="0,12,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="6" Background="#E8F5E9" VerticalAlignment="Center">
                                    <Path Width="14" Height="14" Fill="#2E7D32" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                                </Border>
                                <TextBlock x:Name="TxtBackupInfo" Grid.Column="1" FontSize="12" Foreground="#546E7A" VerticalAlignment="Center" Margin="12,0,0,0" />
                                <TextBlock x:Name="TxtBackupCount" Grid.Column="2" FontSize="20" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Auto-backup Section -->
                        <Border Background="#F8F9FA" CornerRadius="8" Padding="16,14" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="النسخ الاحتياطي التلقائي" FontSize="13" FontWeight="Bold" Foreground="#37474F" Margin="0,0,0,10" />
                                <CheckBox x:Name="ChkBackupOnStartup" Style="{StaticResource SettingsCheckBox}" Content="نسخ احتياطي عند فتح البرنامج"
                                          Checked="OnAutoBackupChanged" Unchecked="OnAutoBackupChanged" />
                                <CheckBox x:Name="ChkBackupOnOperation" Style="{StaticResource SettingsCheckBox}" Content="نسخ احتياطي عند كل عملية"
                                          Checked="OnAutoBackupChanged" Unchecked="OnAutoBackupChanged" />

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="نسخ احتياطي كل" FontSize="13" Foreground="#546E7A" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <ComboBox x:Name="CmbBackupInterval" Grid.Column="1" FontSize="13" Height="36"
                                              SelectionChanged="OnAutoBackupChanged" Padding="8,4">
                                            <ComboBoxItem Content="إيقاف" Tag="0" />
                                            <ComboBoxItem Content="5 دقائق" Tag="5" />
                                            <ComboBoxItem Content="15 دقيقة" Tag="15" />
                                            <ComboBoxItem Content="30 دقيقة" Tag="30" />
                                            <ComboBoxItem Content="ساعة" Tag="60" />
                                            <ComboBoxItem Content="ساعتين" Tag="120" />
                                            <ComboBoxItem Content="6 ساعات" Tag="360" />
                                            <ComboBoxItem Content="12 ساعة" Tag="720" />
                                            <ComboBoxItem Content="يوم" Tag="1440" />
                                        </ComboBox>
                                    </Grid>

                                <Button x:Name="BtnSaveBackupSettings" Click="BtnSaveBackupSettings_Click" Background="#2E7D32" Style="{StaticResource SaveBtn}" HorizontalAlignment="Left" Margin="0,14,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="14" Height="14" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                              Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                                        <TextBlock Text="  حفظ إعدادات النسخ الاحتياطي" Margin="4,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== PRINTER ==================== -->
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardHeader}" Background="#E3F2FD">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1565C0" VerticalAlignment="Center">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock Text="الطباعة" FontSize="15" FontWeight="Bold" Foreground="#1565C0" />
                                <TextBlock Text="اختيار الطابعة الافتراضية للنظام" FontSize="11" Foreground="#64B5F6" Margin="0,1,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="24,20,24,24">
                        <TextBlock Text="الطابعة الافتراضية" Style="{StaticResource FieldLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="8" Padding="2" Grid.Column="0">
                                <ComboBox x:Name="CmbPrinter" Grid.Column="0" Height="36" FontSize="13" DisplayMemberPath="FullName" BorderThickness="0" Padding="10,0" Background="White" />
                            </Border>
                            <Button x:Name="BtnSavePrinter" Click="BtnSavePrinter_Click" Grid.Column="1" Background="#1565C0" Style="{StaticResource SaveBtn}" Margin="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="14" Height="14" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                          Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                                    <TextBlock Text="  حفظ" Margin="4,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnTestPrint" Click="BtnTestPrint_Click" Grid.Column="2" Style="{StaticResource SecBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="14" Height="14" Fill="#546E7A" Stretch="Uniform" VerticalAlignment="Center"
                                          Data="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z" />
                                    <TextBlock Text="  طباعة تجريبية" Margin="4,0,0,0" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Border Background="#F5F7FA" CornerRadius="8" Padding="12,10" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
