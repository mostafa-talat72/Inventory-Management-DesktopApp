<UserControl x:Class="ProductApp.Views.CustomerInvoicesDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="600" MaxWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="28,24,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14" Background="#E8EAF6">
                    <Path Width="22" Height="22" Fill="#1A237E" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock x:Name="TxtTitle" Text="فواتير العميل" FontSize="22" FontWeight="Bold" Foreground="#1A237E" />
                    <TextBlock x:Name="TxtSubtitle" Text="" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                </StackPanel>

                <Button Grid.Column="2" Click="BtnClose_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Accent divider -->
        <Rectangle Grid.Row="0" Height="3" Fill="#1A237E" Margin="28,0,28,0" VerticalAlignment="Bottom" />

        <!-- Summary cards -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16" Margin="28,16,28,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="10" Background="#F0F0FF" Padding="14,10" Margin="0,0,4,0">
                    <StackPanel>
                        <TextBlock Text="عدد الفواتير" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtInvoiceCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#1A237E" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" CornerRadius="10" Background="#E8F5E9" Padding="14,10" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="إجمالي المشتريات" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtTotalAmount" Text="0 ج.م" FontSize="20" FontWeight="Bold" Foreground="#2E7D32" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" CornerRadius="10" Background="#FFF3E0" Padding="14,10" Margin="4,0,0,0">
                    <StackPanel>
                        <TextBlock Text="المتبقي" FontSize="10" Foreground="#90A4AE" />
                        <TextBlock x:Name="TxtRemainingAmount" Text="0 ج.م" FontSize="20" FontWeight="Bold" Foreground="#E65100" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8" Margin="28,0,28,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="قائمة الفواتير" FontSize="15" FontWeight="SemiBold" Foreground="#37474F" VerticalAlignment="Center" Margin="12,0,0,0" />
                <Border x:Name="FilterBar" Grid.Column="1" CornerRadius="8" Background="#F0F0F0" Padding="4,0,4,0" Height="36" HorizontalAlignment="Left">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="BtnUnpaid" CornerRadius="6" Background="#1565C0" Padding="16,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnUnpaid_Click">
                                <TextBlock x:Name="TxtUnpaid" Text="غير مدفوعة" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="BtnPartiallyPaid" CornerRadius="6" Background="Transparent" Padding="14,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnPartiallyPaid_Click" Margin="4,0,0,0">
                                <TextBlock x:Name="TxtPartiallyPaid" Text="مدفوعة جزئياً" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="BtnCancelled" CornerRadius="6" Background="Transparent" Padding="14,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnCancelled_Click" Margin="4,0,0,0">
                                <TextBlock x:Name="TxtCancelled" Text="ملغاة" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="BtnPaid" CornerRadius="6" Background="Transparent" Padding="14,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnPaid_Click" Margin="4,0,0,0">
                                <TextBlock x:Name="TxtPaid" Text="مدفوعة بالكامل" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="BtnAll" CornerRadius="6" Background="Transparent" Padding="16,0" Height="28" Cursor="Hand" MouseLeftButtonDown="BtnAll_Click" Margin="4,0,0,0">
                                <TextBlock x:Name="TxtAll" Text="كل الفواتير" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Invoice cards list -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="28,0,28,12">
            <StackPanel x:Name="InvoicesPanel" />
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="28,0,28,24">
            <Button x:Name="BtnAddOrder" Click="BtnAddOrder_Click"
                    Height="40" Cursor="Hand" Padding="24,0"
                    Background="#1565C0" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Margin="0,0,12,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                إضافة طلب
            </Button>
            <Button x:Name="BtnManageOrders" Click="BtnManageOrders_Click"
                    Height="40" Cursor="Hand" Padding="24,0"
                    Background="#00897B" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Margin="0,0,12,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                عرض كل الطلبات
            </Button>
            <Button Click="BtnClose_Click"
                    Height="40" Cursor="Hand" Padding="24,0"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                إغلاق
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
