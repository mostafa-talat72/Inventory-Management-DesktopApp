<Page x:Class="ProductApp.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft"
      Background="#F0F2F5"
      ScrollViewer.VerticalScrollBarVisibility="Auto"
      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32">
            <!-- Header -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="14" Background="#EDE7F6">
                    <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="#4527A0" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M3,13H8V23H3V13M10,14H15V23H10V14M17,10H22V23H17V10M3,3.03L8,3V11H3V3.03M10,4H15V12H10V4M17,5H22V8H17V5Z" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="لوحة التحكم" FontSize="22" FontWeight="Bold" Foreground="#1A237E" />
                    <TextBlock x:Name="TxtDashboardDate" Text="..." FontSize="12" Foreground="#90A4AE" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>

            <!-- Metrics Rows -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 1: Today stats -->
                <Border Grid.Column="0" Grid.Row="0" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="مبيعات اليوم" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtTodaySales" Text="0 ج.م" FontSize="26" FontWeight="Bold" Foreground="#2E7D32" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#E8F5E9" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#2E7D32" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtTodayCount" Text="0 فاتورة" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Grid.Row="0" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="تكاليف اليوم" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtTodayCost" Text="0 ج.م" FontSize="26" FontWeight="Bold" Foreground="#C62828" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#FFEBEE" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#C62828" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtTodayCostCount" Text="0 فاتورة" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Grid.Row="0" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="أرباح اليوم" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtTodayProfit" Text="0 ج.م" FontSize="26" FontWeight="Bold" Foreground="#1565C0" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#E3F2FD" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#1565C0" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41L9,16.17Z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtTodayProfitMargin" Text="0%" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Row 2: Total stats -->
                <Border Grid.Column="0" Grid.Row="2" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="إجمالي المبيعات" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtTotalSales" Text="0 ج.م" FontSize="26" FontWeight="Bold" Foreground="#2E7D32" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#E8F5E9" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#2E7D32" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtTotalInvoices" Text="0 فاتورة" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Grid.Row="2" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="إجمالي التكاليف" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtTotalCost" Text="0 ج.م" FontSize="26" FontWeight="Bold" Foreground="#C62828" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#FFCDD2" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#B71C1C" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtTotalCostCount" Text="0 فاتورة" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Grid.Row="2" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="إجمالي الأرباح" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtTotalProfit" Text="0 ج.م" FontSize="26" FontWeight="Bold" Foreground="#2E7D32" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#FFF3E0" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#E65100" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtProfitMargin" Text="0%" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Row 3: Customers, Pending, Cancelled -->
                <Border Grid.Column="0" Grid.Row="4" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="العملاء" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtTotalCustomers" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1A237E" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#E0F7FA" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#00838F" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtNewCustomers" Text="0 هذا الشهر" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Grid.Row="4" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="فواتير معلقة" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtPendingInvoices" Text="0" FontSize="26" FontWeight="Bold" Foreground="#F57F17" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#FFF8E1" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#F57F17" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtPendingAmount" Text="0 ج.م" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Grid.Row="4" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="فواتير ملغاة" FontSize="13" Foreground="#78909C" />
                                <TextBlock x:Name="TxtCancelledInvoices" Text="0" FontSize="26" FontWeight="Bold" Foreground="#78909C" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Background="#ECEFF1" VerticalAlignment="Top">
                                <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#78909C" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtCancelledAmount" Text="0 ج.م" FontSize="11" Foreground="#B0BEC5" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Section: Recent Invoices + Quick Actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <!-- Recent Invoices -->
                <Border Grid.Column="0" CornerRadius="16" Background="White" Padding="24">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="18" Height="18" Fill="#1A237E" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 18H6V4h2v5l2.5-1.5L13 9V4h5v16z" />
                            <TextBlock Grid.Column="1" Text="  آخر الفواتير" FontSize="15" FontWeight="Bold" Foreground="#1A237E" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <Border Grid.Column="2" Background="#F5F5F5" CornerRadius="8" Padding="10,4" Cursor="Hand" MouseLeftButtonDown="OpenInvoicesPage">
                                <TextBlock Text="عرض الكل" FontSize="11" Foreground="#1565C0" />
                            </Border>
                        </Grid>
                        <StackPanel x:Name="RecentInvoicesPanel" />
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <Border Grid.Column="2" CornerRadius="16" Background="White" Padding="24">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="#000" /></Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path FlowDirection="LeftToRight" Grid.Column="0" Width="18" Height="18" Fill="#1A237E" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" />
                            <TextBlock Grid.Column="1" Text="  إجراءات سريعة" FontSize="15" FontWeight="Bold" Foreground="#1A237E" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </Grid>

                        <Button Click="OpenNewInvoice" Height="48" Cursor="Hand" Margin="0,0,0,10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="#1A237E" CornerRadius="12" Padding="16,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#283593" /></Trigger>
                                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="b" Property="Background" Value="#0D155B" /></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Path FlowDirection="LeftToRight" Grid.Column="0" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                                <TextBlock Grid.Column="1" Text="  إنشاء فاتورة جديدة" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Button Click="OpenProductsPage" Height="48" Cursor="Hand" Margin="0,0,0,10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1" Padding="16,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#F5F5F5" /></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Path FlowDirection="LeftToRight" Grid.Column="0" Width="18" Height="18" Fill="#1A237E" Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                                <TextBlock Grid.Column="1" Text="  إدارة المنتجات" FontSize="14" FontWeight="SemiBold" Foreground="#1A237E" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Button Click="OpenReportsPage" Height="48" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1" Padding="16,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#F5F5F5" /></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Path FlowDirection="LeftToRight" Grid.Column="0" Width="18" Height="18" Fill="#1A237E" Stretch="Uniform" VerticalAlignment="Center"
                                      Data="M9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4zm2 2H5V5h14v14zm0-16H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" />
                                <TextBlock Grid.Column="1" Text="  عرض التقارير" FontSize="14" FontWeight="SemiBold" Foreground="#1A237E" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
