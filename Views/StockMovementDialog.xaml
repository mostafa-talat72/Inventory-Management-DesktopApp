<UserControl x:Class="ProductApp.Views.StockMovementDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="820" MaxWidth="1300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackground}" Padding="32,24,32,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="16" Background="#FFF3E0">
                    <Path FlowDirection="LeftToRight" Width="26" Height="26" Fill="#E65100" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock Text="سجل حركة المخزون" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <Border Background="{DynamicResource SurfaceBackground}" CornerRadius="8"
                            Padding="10,5" Margin="0,7,0,0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Path FlowDirection="LeftToRight" Width="13" Height="13" Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" />
                            <TextBlock x:Name="TxtSubtitle" Text="" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Button Grid.Column="2" Click="BtnClose_Click" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36" ToolTip="إغلاق" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="0">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        <Rectangle Grid.Row="0" Height="3" Fill="#FF9800" Margin="32,0,32,0" VerticalAlignment="Bottom" />

        <!-- ═══════ SUMMARY CARDS ═══════ -->
        <Border Grid.Row="1" CornerRadius="14" Background="{DynamicResource CardBackground}"
                Padding="20" Margin="32,16,32,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Current Stock -->
                <Border Grid.Column="0" CornerRadius="12" Background="{DynamicResource SurfaceBackground}" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#3F51B5">
                            <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="White" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="المخزون الحالي" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TxtCurrentStock" Text="0" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,3,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Stock Value -->
                <Border Grid.Column="2" CornerRadius="12" Background="{DynamicResource SurfaceBackground}" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#2E7D32">
                            <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="White" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="قيمة المخزون (FIFO)" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TxtStockValue" Text="0 ج.م" FontSize="20" FontWeight="Bold"
                                       Foreground="#2E7D32" Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Movement Count -->
                <Border Grid.Column="4" CornerRadius="12" Background="{DynamicResource SurfaceBackground}" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#E65100">
                            <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="White" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="عدد الحركات" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TxtMovementCount" Text="0" FontSize="20" FontWeight="Bold"
                                       Foreground="#E65100" Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ MOVEMENTS TABLE ═══════ -->
        <Border Grid.Row="2" CornerRadius="14" Background="{DynamicResource CardBackground}"
                Padding="0" Margin="32,0,32,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Table header bar -->
                <Border Grid.Row="0" Padding="24,16,24,14"
                        Background="{DynamicResource CardBackgroundAlt}"
                        CornerRadius="14,14,0,0"
                        BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Path FlowDirection="LeftToRight" Width="16" Height="16"
                                  Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" />
                            <TextBlock Text="الحركات" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource HeadingTextBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                            <Border CornerRadius="10" Background="#FF9800" Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtSubtitle2" Text="" FontSize="11"
                                           FontWeight="SemiBold" Foreground="White" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DataGrid + empty state -->
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                        <DataGrid x:Name="MovementGrid"
                                  AutoGenerateColumns="False"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="None"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceBackground}">
                            <DataGrid.Resources>
                                <!-- Row style -->
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="46" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushLight}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Foreground" Value="{DynamicResource HeadingTextBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <!-- Cell style -->
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="10,0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Foreground" Value="{DynamicResource HeadingTextBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="{DynamicResource HeadingTextBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <!-- Column header style -->
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Height" Value="42" />
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundAlt}" />
                                    <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushLight}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="10,0" />
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <!-- Date -->
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding DateDisplay}" Width="150" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="12" />
                                            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Type -->
                                <DataGridTemplateColumn Header="النوع" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="8,3" Margin="8,0"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding TypeBgColor}" />
                                                </Border.Background>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="7" Height="7" CornerRadius="4"
                                                            VerticalAlignment="Center">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding TypeDotColor}" />
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="{Binding TypeDisplay}" FontSize="11"
                                                               FontWeight="SemiBold" Margin="6,0,0,0"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Foreground>
                                                            <SolidColorBrush Color="{Binding TypeFgColor}" />
                                                        </TextBlock.Foreground>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Quantity -->
                                <DataGridTextColumn Header="الكمية" Binding="{Binding QuantityDisplay}" Width="180" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{Binding QuantityForeground}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Unit Price -->
                                <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPriceDisplay}" Width="110" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="FontSize" Value="12" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{DynamicResource HeadingTextBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Total -->
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalDisplay}" Width="120" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="12" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{DynamicResource HeadingTextBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Reason -->
                                <DataGridTextColumn Header="السبب / المرجع" Binding="{Binding ReasonDisplay}" Width="*" IsReadOnly="True" MinWidth="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Stock After -->
                                <DataGridTextColumn Header="المخزون بعد" Binding="{Binding StockAfterDisplay}" Width="180" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="12" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Actions -->
                                <DataGridTemplateColumn Header="الإجراءات" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <!-- Edit -->
                                                <Button Click="EditMovement_Click" Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Width="32" Height="32" IsEnabled="{Binding CanDelete}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                                                    CornerRadius="7" Padding="0">
                                                                <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#546E7A"
                                                                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                      Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource CardBackgroundAlt}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="ToolTip" Value="تعديل الحركة" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.2" />
                                                                    <Setter Property="Cursor" Value="No" />
                                                                    <Setter Property="ToolTip" Value="مرتبطة بطلب / فاتورة" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <!-- Delete -->
                                                <Button Click="DeleteMovement_Click" Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Width="32" Height="32" Margin="4,0,0,0"
                                                        IsEnabled="{Binding CanDelete}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                                                    CornerRadius="7" Padding="0">
                                                                <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#E53935"
                                                                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                      Data="M19,6.41L17.59,5 12,10.59 6.41,5 5,6.41 10.59,12 5,17.59 6.41,19 12,13.41 17.59,19 19,17.59 13.41,12 19,6.41Z" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="b" Property="Background" Value="#20E53935" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="b" Property="Background" Value="#40E53935" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="ToolTip" Value="حذف" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.2" />
                                                                    <Setter Property="Cursor" Value="No" />
                                                                    <Setter Property="ToolTip" Value="مرتبطة بطلب / فاتورة" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <Border x:Name="EmptyState" Visibility="Collapsed" Background="Transparent">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,56,0,56">
                            <Border Width="80" Height="80" CornerRadius="40"
                                    Background="{DynamicResource SurfaceBackground}" HorizontalAlignment="Center">
                                <Path FlowDirection="LeftToRight" Width="36" Height="36" Fill="{DynamicResource MutedTextBrush}"
                                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M13 2.05V4.05C17.39 4.59 20.5 8.58 19.96 12.97C19.5 16.61 16.64 19.5 13 19.93V21.93C18.5 21.38 22.5 16.5 21.95 11C21.5 6.25 17.73 2.5 13 2.05M11 2.06C9.05 2.25 7.19 3 5.67 4.26L7.1 5.74C8.22 4.84 9.57 4.26 11 4.06V2.06M4.26 5.67C3 7.19 2.25 9.04 2.05 11H4.05C4.24 9.58 4.8 8.23 5.69 7.1L4.26 5.67M15.5 8.5L10.62 13.38L8.5 11.26L7.44 12.32L10.62 15.5L16.56 9.56L15.5 8.5Z" />
                            </Border>
                            <TextBlock x:Name="TxtNoMovements" Text="لا توجد حركات مخزون لهذا المنتج"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,16,0,4" />
                            <TextBlock Text="ابدأ بإضافة مخزون للمنتج"
                                       FontSize="12" Foreground="{DynamicResource MutedTextBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════ FOOTER ═══════ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="32,0,32,28">
            <Button Click="BtnClose_Click" Height="44" Padding="28,0" Cursor="Hand"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <TextBlock Text="إغلاق" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
