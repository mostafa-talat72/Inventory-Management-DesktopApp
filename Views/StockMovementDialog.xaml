<UserControl x:Class="ProductApp.Views.StockMovementDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="750" MaxWidth="1250">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="32,24,32,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="50" Height="50" CornerRadius="16" Background="#FFF3E0">
                    <Path FlowDirection="LeftToRight" Width="24" Height="24" Fill="#E65100" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="سجل حركة المخزون" FontSize="22" FontWeight="Bold" Foreground="#1A237E" />
                    <Border Background="#F0F0FF" CornerRadius="8" Padding="10,5" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#3F51B5" Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" />
                            <TextBlock x:Name="TxtSubtitle" Text="" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#3F51B5" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Button Grid.Column="2" Click="BtnClose_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Height="3" Fill="#FF9800" Margin="32,0,32,0" VerticalAlignment="Bottom" />

        <!-- Summary Cards -->
        <Border Grid.Row="1" CornerRadius="14" Background="White" Padding="20" Margin="32,16,32,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="12" Background="#F0F0FF" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#D0D0FF">
                            <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="#3F51B5" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="المخزون الحالي" FontSize="10" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtCurrentStock" Text="0" FontSize="18" FontWeight="Bold"
                                       Foreground="#1A237E" Margin="0,1,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" CornerRadius="12" Background="#E8F5E9" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#C8E6C9">
                            <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="#2E7D32" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="قيمة المخزون (FIFO)" FontSize="10" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtStockValue" Text="0 ج.م" FontSize="20" FontWeight="Bold" Foreground="#2E7D32" Margin="0,1,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="4" CornerRadius="12" Background="#FFF3E0" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#FFE0B2">
                            <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="#E65100" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L21 8l-9 9z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="عدد الحركات" FontSize="10" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtMovementCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#E65100" Margin="0,1,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Movements Table -->
        <Border Grid.Row="2" CornerRadius="14" Background="White" Padding="0" Margin="32,0,32,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000" />
            </Border.Effect>
            <Grid>
                <Border Padding="24,18,24,14" Background="#FAFAFA" CornerRadius="14,14,0,0" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="الحركات" FontSize="16" FontWeight="SemiBold" Foreground="#37474F" VerticalAlignment="Center" />
                            <Border CornerRadius="10" Background="#FFF3E0" Padding="10,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtSubtitle2" Text="" FontSize="11" FontWeight="SemiBold" Foreground="#E65100" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="440" Margin="0,56,0,0">
                    <DataGrid x:Name="MovementGrid" AutoGenerateColumns="False"
                              AlternatingRowBackground="#F8F9FA"
                              BorderThickness="0"
                              RowHeaderWidth="0" GridLinesVisibility="None"
                              CanUserReorderColumns="False" CanUserResizeColumns="True"
                              CanUserSortColumns="False" CanUserAddRows="False"
                              Background="Transparent"
                              HeadersVisibility="Column">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="44" />
                                <Setter Property="MinHeight" Value="44" />
                                <Setter Property="BorderBrush" Value="#F0F0F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Padding" Value="10,0" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Height" Value="40" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="Foreground" Value="#546E7A" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="8,0" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="التاريخ" Binding="{Binding DateDisplay}" Width="140" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="النوع" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Background="{Binding TypeColor}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding TypeDisplay}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#37474F" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="الكمية" Binding="{Binding QuantityDisplay}" Width="170" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Foreground" Value="{Binding TypeColor}" />
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="FontSize" Value="13" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPriceDisplay}" Width="100" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="FontSize" Value="12" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalDisplay}" Width="120" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="FontSize" Value="12" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="السبب" Binding="{Binding ReasonDisplay}" Width="*" IsReadOnly="True"
                                                MinWidth="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="FontSize" Value="11" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="المخزون بعد" Binding="{Binding StockAfterDisplay}" Width="170" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="FontSize" Value="12" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="الإجراءات" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Click="EditMovement_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" Width="30" Height="30"
                                                    IsEnabled="{Binding CanDelete}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="0">
                                                            <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#546E7A" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#E8EAF6" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#C5CAE9" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="ToolTip" Value="تعديل الحركة" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="ToolTip" Value="مرتبطة بطلب/فاتورة" />
                                                                <Setter Property="Opacity" Value="0.25" />
                                                                <Setter Property="Cursor" Value="No" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="DeleteMovement_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" Width="30" Height="30" Margin="4,0,0,0"
                                                    IsEnabled="{Binding CanDelete}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="0">
                                                            <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#E53935" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  Data="M19,6.41L17.59,5 12,10.59 6.41,5 5,6.41 10.59,12 5,17.59 6.41,19 12,13.41 17.59,19 19,17.59 13.41,12 19,6.41Z" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#FFEBEE" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#FFCDD2" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="ToolTip" Value="حذف" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="ToolTip" Value="مرتبطة بطلب/فاتورة" />
                                                                <Setter Property="Opacity" Value="0.25" />
                                                                <Setter Property="Cursor" Value="No" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>

                <!-- Empty state -->
                <Border x:Name="EmptyState" Visibility="Collapsed"
                        Background="Transparent" Margin="0,56,0,0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,48,0,48">
                        <Border Width="72" Height="72" CornerRadius="36" Background="#F5F5F5"
                                HorizontalAlignment="Center">
                            <Path FlowDirection="LeftToRight" Width="32" Height="32" Fill="#B0BEC5" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" />
                        </Border>
                        <TextBlock x:Name="TxtNoMovements" Text="لا توجد حركات مخزون لهذا المنتج"
                                   FontSize="14" Foreground="#90A4AE" HorizontalAlignment="Center"
                                   Margin="0,14,0,4" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="32,0,32,28">
            <Button Click="BtnClose_Click"
                    Height="44" Padding="28,0" Cursor="Hand"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <TextBlock Text="إغلاق" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
