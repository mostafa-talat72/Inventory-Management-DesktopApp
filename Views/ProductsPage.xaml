<Page x:Class="ProductApp.Views.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wm="clr-namespace:ProductApp.Converters"
      xmlns:converters="clr-namespace:ProductApp.Converters"
      Title="المنتجات"
      FlowDirection="RightToLeft"
      Background="#F0F2F5">
    <Page.Resources>
        <converters:UnitTypeConverter x:Key="UnitTypeConverter" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="المنتجات" Style="{StaticResource PageTitle}" />

        <!-- Search & Actions -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1"
                        Background="#FAFAFA" Margin="0,0,12,0">
                    <TextBox x:Name="SearchBox"
                             wm:WatermarkBehavior.Watermark="بحث عن منتج..."
                             TextChanged="SearchBox_TextChanged"
                             Padding="10,8" BorderThickness="0"
                             Background="Transparent" FontSize="13" />
                </Border>

                <Button Grid.Column="1" x:Name="BtnAddProduct"
                        Click="AddProduct_Click" Margin="0,0,8,0"
                        Height="40" Cursor="Hand"
                        Background="#1A237E" Foreground="White"
                        BorderThickness="0" Padding="18,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" />
                                                <TextBlock Grid.Column="1" Text="إضافة منتج" FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" x:Name="BtnStockIn"
                        Click="StockIn_Click"
                        Height="40" Cursor="Hand"
                        Background="#00897B" Foreground="White"
                        BorderThickness="0" Padding="18,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                                                <TextBlock Grid.Column="1" Text="إضافة مخزون" FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Product Cards -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="ProductsList"
                         SelectionMode="Single"
                         SelectionChanged="ProductsList_SelectionChanged"
                         PreviewMouseDown="ProductsList_PreviewMouseDown"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="CardBorder"
                                                Width="232" Height="148"
                                                Margin="6" CornerRadius="10"
                                                Background="White"
                                                BorderBrush="#EAEAEA" BorderThickness="1"
                                                Cursor="Hand">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.06" Color="#000000" />
                                            </Border.Effect>
                                            <ContentPresenter Margin="14" ContentSource="Content" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#1A237E" />
                                                <Setter TargetName="CardBorder" Property="Background" Value="#F8F8FF" />
                                                <Setter TargetName="CardBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.15" Color="#1A237E" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#90CAF9" />
                                                <Setter TargetName="CardBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.12" Color="#000000" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding Name}"
                                           FontSize="14" FontWeight="Bold" Foreground="#1A237E"
                                           TextTrimming="CharacterEllipsis" MaxWidth="200" />

                                <TextBlock Grid.Row="1" Text="{Binding UnitsDisplay}"
                                           FontSize="11" Foreground="#90A4AE" Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis" MaxWidth="200" />

                                <Border Grid.Row="2" CornerRadius="4" Background="#E8F5E9"
                                        Padding="6,3" VerticalAlignment="Center" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding StockDisplay}"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#2E7D32" />
                                </Border>

                                <Grid Grid.Row="3" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                                        <TextBlock Text="قطاعي:" FontSize="10" Foreground="#90A4AE" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding RetailDisplay}" FontSize="12" FontWeight="Bold" Foreground="#1A237E" Margin="3,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                                        <TextBlock Text="جملة:" FontSize="10" Foreground="#90A4AE" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding WholesaleDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#00897B" Margin="3,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Button Grid.Column="3" Width="28" Height="28" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Click="EditProduct_Click" ToolTip="تعديل المنتج">
                                        <Path Width="14" Height="14" Fill="#78909C" Stretch="Uniform"
                                              Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" />
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="0">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#E3F2FD" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#BBDEFB" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Grid.Column="4" Width="28" Height="28" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Margin="4,0,0,0"
                                            Click="DeleteProduct_Click" ToolTip="حذف المنتج">
                                        <Path Width="14" Height="14" Fill="#EF5350" Stretch="Uniform"
                                              Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" />
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="0">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#FFEBEE" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#FFCDD2" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <!-- Divider -->
        <Border x:Name="DividerLine" Grid.Row="3" Height="1" Background="#E8E8E8" Margin="0,0,0,12" Visibility="Collapsed" />

        <!-- Units Panel -->
        <Border x:Name="UnitsPanel" Grid.Row="4" Style="{StaticResource CardStyle}" 
                Padding="18" Margin="0,0,0,4" Visibility="Collapsed">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30" Height="30" CornerRadius="15" Background="#1A237E" Grid.Column="0">
                        <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                              Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtUnitHeader" Text="مستويات التعبئة" 
                                       FontSize="14" FontWeight="Bold" Foreground="#1A237E" />
                            <TextBlock x:Name="TxtUnitSubHeader" Text="" FontSize="12" Foreground="#78909C" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Click="StockDeduction_Click"
                                Height="32" Cursor="Hand" Padding="14,0"
                                Background="#C62828" Foreground="White"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Path Grid.Column="0" Width="12" Height="12" Fill="White" Stretch="Uniform"
                                                              VerticalAlignment="Center"
                                                              Data="M19,13H5V11H19V13Z" />
                                                        <TextBlock Grid.Column="1" Text="خصم المخزون" FontSize="12" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Click="StockMovement_Click"
                                Height="32" Cursor="Hand" Padding="14,0" Margin="12,0,0,0"
                                Background="#F57F17" Foreground="White"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Path Grid.Column="0" Width="12" Height="12" Fill="White" Stretch="Uniform"
                                                              VerticalAlignment="Center"
                                                              Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" />
                                                        <TextBlock Grid.Column="1" Text="سجل المخزون" FontSize="12" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Click="EditProduct_FromUnits"
                                Height="32" Cursor="Hand" Padding="14,0" Margin="12,0,0,0"
                                Background="#1A237E" Foreground="White"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Path Grid.Column="0" Width="12" Height="12" Fill="White" Stretch="Uniform"
                                                              VerticalAlignment="Center"
                                                              Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" />
                                                        <TextBlock Grid.Column="1" Text="تعديل" FontSize="12" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Unit cards centered -->
                <Border HorizontalAlignment="Center">
                    <ItemsControl x:Name="UnitsCards" Focusable="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="270" MinHeight="120" Margin="0,0,12,8" CornerRadius="10"
                                    Background="White" BorderBrush="#EAEAEA" BorderThickness="1"
                                    Padding="14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06" Color="#000" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Icon + Name + Type -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Border Width="30" Height="30" CornerRadius="15"
                                                Background="{Binding LevelColor}">
                                            <TextBlock Text="{Binding LevelIcon}" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="#37474F" />
                                            <TextBlock Text="{Binding UnitTypeDisplay}" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Contains badge -->
                                    <Border Grid.Row="1" CornerRadius="4" Background="#E3F2FD" Margin="0,10,0,0"
                                            Padding="8,3" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ContainsDisplay}" FontSize="11" 
                                                   Foreground="#1565C0" FontWeight="SemiBold" />
                                    </Border>

                                    <!-- Prices -->
                                    <Grid Grid.Row="3" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="5" Background="#F5F5FF" Padding="10,5" Margin="0,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="قطاعي" FontSize="10" Foreground="#90A4AE" />
                                                <TextBlock Text="{Binding RetailDisplay, StringFormat={}{0:N2} ج.م}" 
                                                           FontSize="14" FontWeight="Bold" Foreground="#1A237E" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" CornerRadius="5" Background="#F1F8E9" Padding="10,5" Margin="4,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="جملة" FontSize="10" Foreground="#90A4AE" />
                                                <TextBlock Text="{Binding WholesaleDisplay, StringFormat={}{0:N2} ج.م}" 
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#2E7D32" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </Border>
            </StackPanel>
        </Border>


    </Grid>
</Page>