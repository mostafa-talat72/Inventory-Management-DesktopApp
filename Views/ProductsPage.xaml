<Page x:Class="ProductApp.Views.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wm="clr-namespace:ProductApp.Converters"
      Title="المنتجات"
      FlowDirection="RightToLeft"
      Background="{DynamicResource AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">

            <!-- Header -->
            <Border CornerRadius="16" Background="{DynamicResource CardBackground}" Padding="28,20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E8EAF6" Offset="0"/>
                                <GradientStop Color="#C5CAE9" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path FlowDirection="LeftToRight" Width="24" Height="24" Fill="#1A237E" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="المنتجات" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="إدارة المنتجات ومستويات التعبئة والأسعار" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnPrintInventory" Click="PrintInventory_Click"
                                Height="42" Padding="18,0" Cursor="Hand"
                                Background="#546E7A" Foreground="White" BorderThickness="0"
                                FontSize="13" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="10"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Data="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z" />
                                            <TextBlock Text="طباعة المخزون" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.75" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnAddProduct" Click="AddProduct_Click"
                                Height="42" Padding="22,0" Cursor="Hand" Margin="10,0,0,0"
                                Background="#1A237E" Foreground="White" BorderThickness="0"
                                FontSize="13" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="10"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" />
                                            <TextBlock Text="إضافة منتج" Margin="8,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.75" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnStockIn" Click="StockIn_Click"
                                Height="42" Padding="22,0" Cursor="Hand" Margin="10,0,0,0"
                                Background="#00897B" Foreground="White" BorderThickness="0"
                                FontSize="13" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="10"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                                            <TextBlock Text="إضافة مخزون" Margin="8,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.88" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.75" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Summary Stats -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#E8EAF6">
                            <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#3F51B5" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="إجمالي المنتجات" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TxtTotalProducts" Text="0" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                    </Border.Effect>
                </Border>
                <Border Grid.Column="2" CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#E8F5E9">
                            <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#2E7D32" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="إجمالي المخزون" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TxtTotalStock" Text="0" FontSize="22" FontWeight="Bold" Foreground="#2E7D32" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                    </Border.Effect>
                </Border>
                <Border Grid.Column="4" CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#FFF3E0">
                            <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#E65100" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="منتجات منخفضة" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TxtLowStock" Text="0" FontSize="22" FontWeight="Bold" Foreground="#E65100" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                    </Border.Effect>
                </Border>
                <Border Grid.Column="6" CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#F3E5F5">
                            <Path FlowDirection="LeftToRight" Width="20" Height="20" Fill="#7B1FA2" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="قيمة المخزون" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock x:Name="TxtStockValue" Text="0 ج.م" FontSize="22" FontWeight="Bold" Foreground="#7B1FA2" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000" />
                    </Border.Effect>
                </Border>
            </Grid>

            <!-- Search -->
            <Border CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="16" Margin="0,0,0,20">
                <Border CornerRadius="10" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                        Background="{DynamicResource SurfaceBackground}" Padding="0" Height="42">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="42" Background="Transparent" CornerRadius="10,0,0,10">
                            <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#B0BEC5" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                        </Border>
                        <TextBox x:Name="SearchBox" Grid.Column="1"
                                 wm:WatermarkBehavior.Watermark="بحث عن منتج..."
                                 TextChanged="SearchBox_TextChanged"
                                 Padding="8,0" BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource HeadingTextBrush}"
                                 CaretBrush="{DynamicResource HeadingTextBrush}"
                                 FontSize="13"
                                 VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Border>

            <!-- Product Grid -->
            <Border CornerRadius="14" Background="{DynamicResource CardBackground}" Padding="16" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.05" Color="#000" />
                </Border.Effect>
                <ItemsControl x:Name="ProductsList" Focusable="False"
                              HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="248" Height="200" Margin="7" CornerRadius="14"
                                        Background="{DynamicResource CardBackground}" BorderBrush="#EDEDED" BorderThickness="1"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}" />
                                    </Border.InputBindings>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#000" />
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#90CAF9" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="14" ShadowDepth="4" Opacity="0.12" Color="#1A237E" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="16,14,16,14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Name + Actions -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="15" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Width="28" Height="28" CornerRadius="7"
                                                    Background="Transparent" Cursor="Hand"
                                                    ToolTip="تعديل" Margin="2,0">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding EditCommand}" />
                                                </Border.InputBindings>
                                                <Path FlowDirection="LeftToRight" Width="13" Height="13" Fill="#78909C" Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" />
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E8EAF6" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <Border Grid.Column="2" Width="28" Height="28" CornerRadius="7"
                                                    Background="Transparent" Cursor="Hand"
                                                    ToolTip="حذف">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding DeleteCommand}" />
                                                </Border.InputBindings>
                                                <Path FlowDirection="LeftToRight" Width="13" Height="13" Fill="#EF5350" Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" />
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFEBEE" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>

                                        <!-- Row 1: Units path -->
                                        <Border Grid.Row="1" CornerRadius="5" Background="{DynamicResource CardBackgroundAlt}"
                                                Padding="8,4" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding UnitsDisplay}" FontSize="10"
                                                       Foreground="{DynamicResource SubtleTextBrush}" TextTrimming="CharacterEllipsis" />
                                        </Border>

                                        <!-- Row 2: Stock + Value -->
                                        <Grid Grid.Row="2" Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="8"
                                                    Background="{Binding StockBgColor}"
                                                    Padding="6,5" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Path FlowDirection="LeftToRight" Width="12" Height="12" Fill="{Binding StockFgColor}" Stretch="Uniform"
                                                          VerticalAlignment="Center"
                                                          Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.2V15.91M13,19.29L19,15.91V9.2L13,12.58V19.29Z" />
                                                    <TextBlock Text="{Binding StockDisplay}" FontSize="11" FontWeight="Bold"
                                                               Foreground="{Binding StockFgColor}" Margin="4,0,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="2" CornerRadius="8"
                                                    Background="{DynamicResource SurfaceBackground}"
                                                    Padding="6,5" VerticalAlignment="Center"
                                                    BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="قيمة:" FontSize="9"
                                                               Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding StockValueDisplay}" FontSize="11" FontWeight="Bold"
                                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="3,0,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Row 3: Prices -->
                                        <Grid Grid.Row="3" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="6" Background="#F0F0FF" Padding="8,4" Margin="0,0,3,0">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="قطاعي:" FontSize="9" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding RetailDisplay}"
                                                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="3,0,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" CornerRadius="6" Background="#F1F8E9" Padding="8,4" Margin="3,0,0,0">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="جملة:" FontSize="9" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding WholesaleDisplay}"
                                                               FontSize="12" FontWeight="SemiBold" Foreground="#2E7D32" Margin="3,0,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
