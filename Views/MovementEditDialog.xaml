<UserControl x:Class="ProductApp.Views.MovementEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="420" MaxWidth="560">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with accent bar -->
        <Border Grid.Row="0" Background="White" Padding="24,24,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14" Background="#E8EAF6">
                    <Path FlowDirection="LeftToRight" Width="22" Height="22" Fill="#1A237E" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock x:Name="TxtTitle" Text="تعديل الحركة" FontSize="20" FontWeight="Bold" Foreground="#1A237E" />
                    <TextBlock x:Name="TxtSubtitle" Text="" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                </StackPanel>

                <Button Grid.Column="2" Click="BtnCancel_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق"
                        VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Accent divider -->
        <Rectangle Grid.Row="0" Height="3" Fill="#1A237E" Margin="24,0,24,0" VerticalAlignment="Bottom" />

        <!-- Content -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="24,16,24,12">
            <StackPanel>
                <StackPanel x:Name="QtySection" Margin="0,0,0,12">
                    <TextBlock Text="الكمية" FontSize="12" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,0,6" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="كرتونة" FontSize="10" Foreground="#90A4AE" Margin="0,0,0,2" />
                            <TextBox x:Name="TxtCartonQty" Text="0" TextAlignment="Center"
                                     Padding="6,4" FontSize="14" BorderBrush="#E0E0E0" BorderThickness="1"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                     TextChanged="Qty_TextChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,4,0">
                            <TextBlock Text="علبة" FontSize="10" Foreground="#90A4AE" Margin="0,0,0,2" />
                            <TextBox x:Name="TxtBoxQty" Text="0" TextAlignment="Center"
                                     Padding="6,4" FontSize="14" BorderBrush="#E0E0E0" BorderThickness="1"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                     TextChanged="Qty_TextChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="4,0,0,0">
                            <TextBlock Text="قطعة" FontSize="10" Foreground="#90A4AE" Margin="0,0,0,2" />
                            <TextBox x:Name="TxtPieceQty" Text="0" TextAlignment="Center"
                                     Padding="6,4" FontSize="14" BorderBrush="#E0E0E0" BorderThickness="1"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                     TextChanged="Qty_TextChanged" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border CornerRadius="8" Background="#F5F5FF" Padding="14,10" Margin="0,0,12,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="التكلفة الإجمالية" FontSize="11" Foreground="#90A4AE" />
                            <TextBox x:Name="TxtTotalCost" TextAlignment="Center"
                                     Padding="6,4" FontSize="14" FontWeight="Bold" Foreground="#1A237E"
                                     BorderBrush="#C5CAE9" BorderThickness="1" Margin="0,2,0,0"
                                     TextChanged="TotalCost_TextChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="سعر القطعة" FontSize="11" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtCostPerPiece" Text="-" FontSize="16" FontWeight="Bold" Foreground="#F57F17" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border CornerRadius="8" Background="#F5F5FF" Padding="14,10" Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="متوسط سعر الوحدة (FIFO)" FontSize="11" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtFifoCost" Text="-" FontSize="16" FontWeight="Bold" Foreground="#1A237E" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="المخزون المتاح" FontSize="11" Foreground="#90A4AE" />
                            <TextBlock x:Name="TxtAvailableStock" Text="-" FontSize="16" FontWeight="Bold" Foreground="#2E7D32" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,4,24,24">
            <Button Click="BtnSave_Click"
                    Height="40" Cursor="Hand" Padding="24,0"
                    Background="#1A237E" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41L9,16.17Z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                حفظ التعديلات
            </Button>
            <Button Click="BtnCancel_Click"
                    Height="40" Cursor="Hand" Padding="24,0" Margin="12,0,0,0"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                إلغاء
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
