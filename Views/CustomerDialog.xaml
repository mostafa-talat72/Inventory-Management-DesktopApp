<UserControl x:Class="ProductApp.Views.CustomerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wm="clr-namespace:ProductApp.Converters"
             FlowDirection="RightToLeft"
             MinWidth="420" MaxWidth="560">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with accent bar -->
        <Border Grid.Row="0" Background="White" Padding="24,24,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14" Background="#E8EAF6">
                    <Path Width="22" Height="22" Fill="#1A237E" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock x:Name="TxtHeader" Text="بيانات العميل" FontSize="20" FontWeight="Bold" Foreground="#1A237E" />
                    <TextBlock Text="أدخل بيانات العميل الجديد" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0" />
                </StackPanel>

                <Button Grid.Column="2" Click="BtnCancel_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36"
                        ToolTip="إغلاق"
                        VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="0">
                                <Path Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Accent divider -->
        <Rectangle Grid.Row="0" Height="3" Fill="#1A237E" Margin="24,0,24,0" VerticalAlignment="Bottom" />

        <!-- Form -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="24" Margin="24,20,24,12">
            <StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="الاسم" FontSize="12" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,0,6" />
                    <Border CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                        <TextBox x:Name="TxtName"
                                 wm:WatermarkBehavior.Watermark="اسم العميل *"
                                 Padding="12,10" BorderThickness="0"
                                 Background="Transparent" FontSize="13" />
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="رقم الهاتف" FontSize="12" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,0,6" />
                    <Border CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                        <TextBox x:Name="TxtPhone"
                                 wm:WatermarkBehavior.Watermark="رقم الهاتف"
                                 Padding="12,10" BorderThickness="0"
                                 Background="Transparent" FontSize="13" />
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="العنوان" FontSize="12" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,0,6" />
                    <Border CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                        <TextBox x:Name="TxtAddress"
                                 wm:WatermarkBehavior.Watermark="العنوان"
                                 Padding="12,10" BorderThickness="0"
                                 Background="Transparent" FontSize="13" />
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,0">
                    <TextBlock Text="ملاحظات" FontSize="12" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,0,6" />
                    <Border CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                        <TextBox x:Name="TxtNotes"
                                 wm:WatermarkBehavior.Watermark="ملاحظات (اختياري)"
                                 Padding="12,10" BorderThickness="0"
                                 Background="Transparent" FontSize="13" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,4,24,24">
            <Button Click="BtnSave_Click"
                    Height="40" Cursor="Hand" Padding="24,0"
                    Background="#1A237E" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41L9,16.17Z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                حفظ
            </Button>
            <Button Click="BtnCancel_Click"
                    Height="40" Cursor="Hand" Padding="24,0" Margin="12,0,0,0"
                    Background="#78909C" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Fill="White" Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                إلغاء
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
