<UserControl x:Class="ProductApp.Views.InvoiceDetailsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="1000" MaxWidth="1800" MaxHeight="660">
    <Border CornerRadius="16" Background="White" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== FIXED HEADER ===== -->
            <Border Grid.Row="0" Padding="32,24,32,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="16" Background="#E8F5E9">
                        <Path FlowDirection="LeftToRight" Width="28" Height="28" Fill="#2E7D32" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="18,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTitle" Text="فاتورة #0" FontSize="26" FontWeight="Bold" Foreground="#1A237E" />
                            <Border x:Name="StatusBadge" CornerRadius="6" Padding="14,5" Margin="14,0,0,0" VerticalAlignment="Center" Background="#E8F5E9">
                                <TextBlock x:Name="TxtStatus" Text="مدفوعة" FontSize="11" FontWeight="Bold" Foreground="#2E7D32" />
                            </Border>
                            <Button x:Name="BtnAddOrder" Click="BtnAddOrder_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center"
                                    ToolTip="إضافة طلب للفاتورة">
                                <Border CornerRadius="6" Padding="8,4" Background="#E8F5E9">
                                    <StackPanel Orientation="Horizontal">
                                        <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#2E7D32" Stretch="Uniform" VerticalAlignment="Center"
                                              Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                                        <TextBlock Text="إضافة طلب" FontSize="11" FontWeight="Bold" Foreground="#2E7D32" Margin="4,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button x:Name="BtnManageOrders" Click="BtnManageOrders_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center"
                                    ToolTip="عرض كل طلبات الفاتورة">
                                <Border CornerRadius="6" Padding="8,4" Background="#E8EAF6">
                                    <StackPanel Orientation="Horizontal">
                                        <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#1A237E" Stretch="Uniform" VerticalAlignment="Center"
                                              Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                        <TextBlock Text="كل الطلبات" FontSize="11" FontWeight="Bold" Foreground="#1A237E" Margin="4,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button x:Name="BtnTransfer" Click="BtnTransfer_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center"
                                    ToolTip="نقل الفاتورة إلى عميل آخر أو نقدي">
                                <Border CornerRadius="6" Padding="8,4" Background="#E3F2FD">
                                    <StackPanel Orientation="Horizontal">
                                        <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#1976D2" Stretch="Uniform" VerticalAlignment="Center"
                                              Data="M15 20a1 1 0 0 0 1-1V5l4 4a1 1 0 0 0 1.42-1.42l-6-6a1 1 0 0 0-1.42 0l-6 6A1 1 0 0 0 9.58 9.58L14 5v14a1 1 0 0 0 1 1z" />
                                        <TextBlock Text="نقل" FontSize="11" FontWeight="Bold" Foreground="#1976D2" Margin="4,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#546E7A" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M12 12c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm0-10c4.2 0 8 3.22 8 8.2 0 3.32-2.67 7.25-8 11.8-5.33-4.55-8-8.48-8-11.8C4 5.22 7.8 2 12 2z" />
                            <TextBlock x:Name="TxtCustomerName" Text="" FontSize="13" Foreground="#546E7A" Margin="6,0,0,0" />
                            <TextBlock Text="•" FontSize="16" Foreground="#CFD8DC" Margin="12,0,12,0" />
                            <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#90A4AE" Stretch="Uniform" VerticalAlignment="Center"
                                  Data="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z" />
                            <TextBlock x:Name="TxtInvoiceDate" Text="" FontSize="12" Foreground="#90A4AE" Margin="6,0,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2" Click="BtnClose_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Width="38" Height="38"
                            ToolTip="إغلاق" VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        CornerRadius="10" Padding="0">
                                    <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="#78909C" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Accent divider -->
            <Rectangle Grid.Row="0" Height="3" Fill="#2E7D32" Margin="32,0,32,0" VerticalAlignment="Bottom" />

            <!-- ===== FIXED SUMMARY CARDS ===== -->
            <Border Grid.Row="1" Padding="32,20,32,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="14" Background="#EEEEFF" Padding="20,16" Margin="0,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#5C6BC0" Opacity="0.15">
                                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#5C6BC0" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                                </Border>
                                <TextBlock Text="الإجمالي" FontSize="11" Foreground="#5C6BC0" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="TxtTotal" Text="0 ج.م" FontSize="22" FontWeight="Bold" Foreground="#283593" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="14" Background="#FFF8E1" Padding="20,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#F9A825" Opacity="0.15">
                                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#F9A825" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                                </Border>
                                <TextBlock Text="الخصم" FontSize="11" Foreground="#F57F17" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="TxtDiscount" Text="0 ج.م" FontSize="22" FontWeight="Bold" Foreground="#E65100" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" CornerRadius="14" Background="#E8F5E9" Padding="20,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#43A047" Opacity="0.15">
                                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#43A047" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                                </Border>
                                <TextBlock Text="المدفوع" FontSize="11" Foreground="#2E7D32" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="TxtPaid" Text="0 ج.م" FontSize="22" FontWeight="Bold" Foreground="#1B5E20" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" CornerRadius="14" Background="#FFEBEE" Padding="20,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#E53935" Opacity="0.15">
                                    <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="#E53935" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z" />
                                </Border>
                                <TextBlock Text="المتبقي" FontSize="11" Foreground="#C62828" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="TxtRemaining" Text="0 ج.م" FontSize="22" FontWeight="Bold" Foreground="#B71C1C" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ===== SCROLLABLE BODY: Products | Discounts | Payments ===== -->
            <Border Grid.Row="2" Margin="32,20,32,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Products column -->
                    <Grid x:Name="ProductsSection" Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6" Background="#E8EAF6">
                                <Path FlowDirection="LeftToRight" Width="12" Height="12" Fill="#3F51B5" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="المنتجات المباعة" FontSize="15" FontWeight="Bold" Foreground="#37474F" Margin="10,0,0,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtItemCount" Grid.Column="2" Text="0 منتج" FontSize="12" Foreground="#90A4AE" VerticalAlignment="Center" />
                        </Grid>
                        <Border Grid.Row="1" CornerRadius="12" Background="#F8F9FA">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,8">
                                <StackPanel x:Name="ItemsPanel" />
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- Discounts column -->
                    <Grid x:Name="DiscountsSection" Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6" Background="#FFF8E1">
                                <Path FlowDirection="LeftToRight" Width="12" Height="12" Fill="#F57F17" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="الخصومات" FontSize="15" FontWeight="Bold" Foreground="#37474F" Margin="10,0,0,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtDiscountCount" Grid.Column="2" Text="0 خصم" FontSize="12" Foreground="#90A4AE" VerticalAlignment="Center" />
                        </Grid>
                        <Border Grid.Row="1" CornerRadius="12" Background="#F8F9FA">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,8">
                                <StackPanel x:Name="DiscountsPanel" />
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- Payments column -->
                    <Grid x:Name="PaymentsSection" Grid.Column="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6" Background="#E8F5E9">
                                <Path FlowDirection="LeftToRight" Width="12" Height="12" Fill="#2E7D32" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="المدفوعات" FontSize="15" FontWeight="Bold" Foreground="#37474F" Margin="10,0,0,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtPaymentCount" Grid.Column="2" Text="0 دفعة" FontSize="12" Foreground="#90A4AE" VerticalAlignment="Center" />
                        </Grid>
                        <Border Grid.Row="1" CornerRadius="12" Background="#F8F9FA">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,8">
                                <StackPanel x:Name="PaymentsPanel" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== FIXED FOOTER: Buttons ===== -->
            <Border Grid.Row="3" Background="#FAFAFA" Padding="40,20,40,28" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,32,0">
                        <Button x:Name="BtnPrint" Click="BtnPrint_Click"
                                Height="44" Cursor="Hand" Padding="28,0"
                                Background="#546E7A" Foreground="White" BorderThickness="0"
                                FontSize="14" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                                  Data="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z" />
                                            <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            طباعة
                        </Button>
                        <Button x:Name="BtnDeleteInvoice" Click="BtnDeleteInvoice_Click"
                                Height="44" Cursor="Hand" Padding="28,0" Margin="14,0,0,0"
                                Background="#C62828" Foreground="White" BorderThickness="0"
                                FontSize="14" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                                  Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                                            <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            حذف الفاتورة
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnDiscount" Click="BtnDiscount_Click"
                                Height="44" Cursor="Hand" Padding="28,0"
                                Background="#F57F17" Foreground="White" BorderThickness="0"
                                FontSize="14" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                                            <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            خصم
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="32,0,0,0">
                        <Button x:Name="BtnPayFull" Click="BtnPayFull_Click"
                                Height="44" Cursor="Hand" Padding="28,0"
                                Background="#2E7D32" Foreground="White" BorderThickness="0"
                                FontSize="14" FontWeight="SemiBold" Margin="0,0,14,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                                            <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            دفع الفاتورة كاملاً
                        </Button>
                        <Button x:Name="BtnPayPartial" Click="BtnPayPartial_Click"
                                Height="44" Cursor="Hand" Padding="28,0"
                                Background="#F57F17" Foreground="White" BorderThickness="0"
                                FontSize="14" FontWeight="SemiBold" Margin="0,0,14,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path FlowDirection="LeftToRight" Width="18" Height="18" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
