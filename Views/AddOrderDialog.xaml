<UserControl x:Class="ProductApp.Views.AddOrderDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             MinWidth="960" MaxWidth="1300" MaxHeight="700">
    <Border CornerRadius="14" Background="{DynamicResource AppBackground}" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.3" Color="#1A237E" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1A237E" CornerRadius="14,14,0,0" Padding="22,13,22,13">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="#3949AB">
                        <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="إضافة طلب" FontSize="17" FontWeight="Bold" Foreground="White" />
                        <TextBlock x:Name="TxtSubtitle" Text="" FontSize="10" Foreground="#9FA8DA" Margin="0,1,0,0" />
                    </StackPanel>
                    <Border x:Name="InvoiceBadge" CornerRadius="6" Background="#283593" Padding="10,5" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="فاتورة #" FontSize="11" Foreground="#9FA8DA" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtInvoiceId" Text="0" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="3,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" x:Name="CartBadge" CornerRadius="12" Background="#FF8F00" Padding="9,4" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="TxtCartCount" Text="0" FontSize="11" FontWeight="Bold" Foreground="White" />
                    </Border>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- RIGHT: Current Order (Column 1 in RTL = visually left) -->
                <!-- Actually RTL: Column 0 = right, Column 1 = left -->
                <!-- User wants Order on the right → Column 0, Products on left → Column 1 -->
                <Border Grid.Column="0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Order header -->
                        <Border Grid.Row="0" Padding="18,14,18,10" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7" Background="#E8EAF6">
                                    <Path FlowDirection="LeftToRight" Width="12" Height="12" Fill="#1A237E" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M17 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="الطلب الحالي" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <Border Grid.Column="2" CornerRadius="4" Background="{DynamicResource CardBackgroundAlt}" Padding="8,3" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtItemCount" Text="0" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Order items -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,8,14,4" BorderThickness="0">
                            <ScrollViewer.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ScrollBarBrushKey}" Color="#E8EAF6" />
                            </ScrollViewer.Resources>
                            <StackPanel x:Name="OrderItemsPanel" />
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="2" Background="{DynamicResource SurfaceBackground}" Padding="18,10,18,14" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="الإجمالي" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="TxtGrandTotal" Text="0 ج.م" FontSize="19" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Click="BtnCancel_Click"
                                            Height="40" Cursor="Hand"
                                            Background="{DynamicResource CardBackgroundAlt}" Foreground="{DynamicResource BodyTextBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                            FontSize="13" FontWeight="SemiBold">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        إلغاء
                                    </Button>
                                    <Button Grid.Column="1" x:Name="BtnSave" Click="BtnSaveOrder_Click"
                                            Height="40" Cursor="Hand" Padding="22,0" Margin="8,0,0,0"
                                            Background="#1A237E" Foreground="White" BorderThickness="0"
                                            FontSize="13" FontWeight="Bold" IsEnabled="False">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}" Opacity="{TemplateBinding Opacity}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path FlowDirection="LeftToRight" Width="16" Height="16" Fill="White" Stretch="Uniform" VerticalAlignment="Center"
                                                              Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" />
                                                        <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#B0BEC5" />
                                                        <Setter Property="Cursor" Value="Arrow" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        حفظ الطلب
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- LEFT: Products (Column 1 in RTL = visually left) -->
                <Border Grid.Column="1" Background="{DynamicResource SurfaceBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Border Grid.Row="0" Padding="18,12,18,8">
                            <Border CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0" Background="{DynamicResource CardBackground}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Background="Transparent">
                                        <Path FlowDirection="LeftToRight" Width="14" Height="14" Fill="#90A4AE" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                                    </Border>
                                    <TextBox Grid.Column="1" x:Name="TxtSearch" FontSize="13" Padding="0,8,4,8" BorderThickness="0" Background="Transparent"
                                             TextChanged="TxtSearch_TextChanged" />
                                </Grid>
                            </Border>
                        </Border>

                        <!-- Product cards -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,2,14,12">
                            <ScrollViewer.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ScrollBarBrushKey}" Color="#E8EAF6" />
                            </ScrollViewer.Resources>
                            <ItemsControl x:Name="ProductCards">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="150" Height="82" Margin="4" CornerRadius="10"
                                                Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushLight}" BorderThickness="1"
                                                Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.05" Color="#1A237E" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.9" Duration="0:0:0.15" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                            <Setter Property="BorderBrush" Value="#3949AB" />
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.12" Color="#3949AB" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}" />
                                            </Border.InputBindings>
                                            <Grid Margin="10,8,10,6">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="1" Text="{Binding StockDisplay}" FontSize="10" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,2,0,0" />
                                                <TextBlock Grid.Row="2" Text="{Binding PriceDisplay}" FontSize="10" Foreground="#00897B" VerticalAlignment="Bottom" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
